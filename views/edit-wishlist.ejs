<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CardVault - Edit Wishlist Item</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #0a0c12;
            background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%);
            font-family: Archivo, system-ui, sans-serif;
        }
        .form-card {
            background: #12151e;
            border: 1px solid rgba(203, 166, 95, .25);
            border-radius: 12px;
            box-shadow: 0 24px 60px rgba(0, 0, 0, .55);
            padding: 2.5rem;
        }

        /* ==== CardVault dark vault theme ==== */
        h2 { font-family: 'Instrument Serif', serif; font-weight: 400 !important; color: #f2ede1; }
        .text-muted { color: #8a90a4 !important; }
        .form-card hr { border-color: rgba(203,166,95,.35); opacity: 1; }
        .form-label { color: #d8dce8; }
        .form-control, .form-select { background-color: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.14); color: #f2ede1; }
        .form-control:focus, .form-select:focus { background-color: rgba(255,255,255,.04); border-color: rgba(203,166,95,.7); color: #f2ede1; box-shadow: 0 0 0 .25rem rgba(203,166,95,.15); }
        .form-control::placeholder { color: #5a6175; }
        .form-select option { background: #12151e; color: #f2ede1; }
        .form-control[type=file]::file-selector-button { background: rgba(214,179,106,.15); border: none; color: #cba65f; }
        .btn-success { background: linear-gradient(180deg, #e0bf7c, #c9a35c); border: none; color: #1c1508; font-weight: 600; }
        .btn-success:hover { background: linear-gradient(180deg, #e8c988, #d3ad64); color: #1c1508; }
        .btn-secondary { background: transparent; border: 1px solid rgba(255,255,255,.24); color: #e8e4d8; }
        .btn-secondary:hover { background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.5); color: #fff; }
    </style>
</head>

<body>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-7">

            <div class="form-card">
                <h2 class="fw-bold text-center mb-2">Edit Wishlist Item</h2>
                <p class="text-muted text-center mb-4">Update the details of a card you're hunting for.</p>
                <hr class="mb-4">

                <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
                    <div class="alert alert-danger">
                        <% messages.forEach(function(msg){ %><div><%= msg %></div><% }); %>
                    </div>
                <% } %>

                <!-- Current image preview -->
                <div class="text-center mb-4">
                    <img src="/images/<%= item.image || 'default.png' %>"
                         alt="<%= item.card_name %>"
                         onerror="this.onerror=null;this.src='/images/default.png';"
                         style="max-height:200px; max-width:100%; object-fit:contain; border-radius:8px;">
                </div>

                <form action="/edit-wishlist/<%= item.wishlist_id %>" method="POST" enctype="multipart/form-data">

                    <!-- Keeps the old image path if the user doesn't choose a new file -->
                    <input type="hidden" name="existing_image" value="<%= item.image %>">

                    <!-- Row 1: Card Name -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Card Name</label>
                        <input type="text" class="form-control" name="card_name" value="<%= item.card_name %>" required>
                    </div>

                    <!-- Row 2: Category & Target Price -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Category / Franchise</label>
                            <select class="form-select" name="category" required>
                                <option value="" disabled>Select Category</option>
                                <% ['digimon','football','formula 1','NBA','One Piece','Pokemon','Yu-Gi-Oh!'].forEach(function(cat) { %>
                                    <option <%= item.category === cat ? 'selected' : '' %>><%= cat %></option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Target Price (S$)</label>
                            <input type="number" step="0.01" class="form-control" name="target_price"
                                   value="<%= item.target_price !== null ? item.target_price : '' %>"
                                   placeholder="Optional — leave blank if not set" min="0">
                        </div>
                    </div>

                    <!-- Row 3: Notes -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Notes</label>
                        <textarea class="form-control" name="notes" rows="3"
                                  placeholder="Where to find it, price alerts, etc. (optional)"><%= item.notes || '' %></textarea>
                    </div>

                    <!-- Row 4: Image Upload -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Replace Card Image (optional)</label>
                        <input type="file" class="form-control" name="image" accept="image/*">
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a href="/wishlist" class="btn btn-secondary px-4 me-md-2">Cancel</a>
                        <button type="submit" class="btn btn-success px-5 fw-semibold">Save Changes</button>
                    </div>

                </form>
            </div>

        </div>
    </div>
</div>

</body>
</html>
