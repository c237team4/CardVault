<%- include('partials/header', { title: 'Add Collection Goal', user: user }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
body{
    background:#0a0c12;
    color:#d8dae0;
}

.goal-form{
    background:linear-gradient(160deg,#12151d,#0d1016);
    border:1px solid rgba(203,166,95,.28);
    border-radius:14px;
    box-shadow:0 18px 48px rgba(0,0,0,.55);
}

h1{
    font-family:'Instrument Serif',serif;
    color:#f4f2ee;
    font-size:3rem;
}

.form-control,
.form-select{
    background:#1b1e26;
    color:#fff;
    border:1px solid #3a3d45;
}

.form-control:focus,
.form-select:focus{
    background:#1b1e26;
    color:#fff;
    border-color:#cba65f;
    box-shadow:none;
}

.btn-gold{
    background:linear-gradient(180deg,#e0bf7c,#cba65f);
    color:#0a0c12;
    border:none;
    font-weight:600;
}

.btn-gold:hover{
    background:linear-gradient(180deg,#ecca88,#d9b46e);
    color:#0a0c12;
}

.btn-cancel{
    border:1px solid rgba(203,166,95,.5);
    color:#e0bf7c;
}

.btn-cancel:hover{
    background:rgba(203,166,95,.15);
    color:white;
}
</style>

<div class="container my-5" style="max-width:700px;">

<div class="goal-form p-5">

<h1 class="mb-4">Add Collection Goal</h1>

<form action="/add-goal" method="POST">

<div class="mb-3">
<label>Goal Name</label>
<input type="text" name="goal_name" class="form-control" required>
</div>

<div class="mb-3">
<label>Description</label>
<textarea name="description" class="form-control" rows="3"></textarea>
</div>

<div class="mb-3">
<label>Target Cards</label>
<input type="number" name="target_cards" class="form-control" required>
</div>

<div class="mb-3">
<label>Current Cards</label>
<input type="number" name="current_cards" class="form-control" value="0" required>
</div>

<div class="mb-4">
<label>Status</label>
<select name="status" class="form-select">
<option>In Progress</option>
<option>Completed</option>
</select>
</div>

<button class="btn btn-gold">Add Goal</button>

<a href="/goals" class="btn btn-cancel ms-2">Cancel</a>

</form>

</div>

</div>

<%- include('partials/footer') %>