<%- include('partials/header', { title: 'Add to Wishlist - CardVault' }) %>

<!-- ============================================================
     ADD TO WISHLIST  |  Owner: wishlist team - Create
     A logged-in member adds a "grail card" they are hunting for.
     Posts to: POST /add-wishlist
     Fields match the wishlist table: card_name, category,
     target_price (optional), notes (optional).
     ============================================================ -->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ==== CardVault dark vault theme ==== */
body { background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%); font-family: Archivo, system-ui, sans-serif; }
.form-card { background:#12151e; border:1px solid rgba(203,166,95,.25); border-radius:12px; box-shadow:0 24px 60px rgba(0,0,0,.55); padding:2.5rem; }
h2 { font-family:'Instrument Serif',serif; font-weight:400 !important; color:#f2ede1; }
.text-muted { color:#8a90a4 !important; }
.form-card hr { border-color:rgba(203,166,95,.35); opacity:1; }
.form-label { color:#d8dce8; }
.form-control { background-color:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.14); color:#f2ede1; }
.form-control:focus { background-color:rgba(255,255,255,.04); border-color:rgba(203,166,95,.7); color:#f2ede1; box-shadow:0 0 0 .25rem rgba(203,166,95,.15); }
.form-control::placeholder { color:#5a6175; }
.btn-success { background:linear-gradient(180deg,#e0bf7c,#c9a35c); border:none; color:#1c1508; font-weight:600; }
.btn-success:hover { background:linear-gradient(180deg,#e8c988,#d3ad64); color:#1c1508; }
.btn-secondary { background:transparent; border:1px solid rgba(255,255,255,.24); color:#e8e4d8; }
.btn-secondary:hover { background:rgba(255,255,255,.06); border-color:rgba(255,255,255,.5); color:#fff; }
</style>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="form-card">

        <h2 class="fw-bold text-center mb-2">Add to Wishlist</h2>
        <p class="text-muted text-center mb-4">A card you're hunting for, not yet in your collection.</p>
        <hr class="mb-4">

        <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
          <div class="alert alert-danger">
            <% messages.forEach(function(msg){ %><div><%= msg %></div><% }); %>
          </div>
        <% } %>

        <form action="/add-wishlist" method="POST">

          <div class="mb-3">
            <label class="form-label fw-semibold">Card Name</label>
            <input type="text" class="form-control" name="card_name"
                   placeholder="e.g., Charizard 1st Edition Holo" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Category / Franchise</label>
            <input type="text" class="form-control" name="category"
                   placeholder="e.g., Pokemon, NBA, One Piece" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Target Price (S$) <span class="text-muted">— optional</span></label>
            <input type="number" step="0.01" min="0" class="form-control" name="target_price"
                   placeholder="The most you'd pay">
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">Notes <span class="text-muted">— optional</span></label>
            <textarea class="form-control" name="notes" rows="3"
                      placeholder="e.g., must be PSA 9 or above"></textarea>
          </div>

          <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <a href="/wishlist" class="btn btn-secondary px-4 me-md-2">Cancel</a>
            <button type="submit" class="btn btn-success">Add to Wishlist</button>
          </div>

        </form>

      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
