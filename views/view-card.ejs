<%- include('partials/header', { title: card.card_name + ' - CardVault' }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ==== CardVault dark vault theme — styling overrides only ==== */
body { background: #0a0c12; font-family: Archivo, system-ui, sans-serif; }
.bg-light { background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%) !important; }
h1, h2 { font-family: 'Instrument Serif', serif; font-weight: 400 !important; }
h1.text-dark, h2.text-dark { color: #f2ede1 !important; }
.text-secondary { color: #8a90a4 !important; }
.card { background: #12151e; border: 1px solid rgba(203,166,95,.25) !important; }
.shadow-lg { box-shadow: 0 24px 60px rgba(0,0,0,.55) !important; }
.card-body { color: #d8dce8; }
.card-body img.shadow { box-shadow: 0 20px 50px rgba(0,0,0,.6) !important; }
.table { color: #d8dce8; }
.table > :not(caption) > * > * { background: transparent; color: #d8dce8; }
.table th.text-secondary { color: #8a90a4 !important; font: 600 12px Archivo, sans-serif; letter-spacing: .12em; text-transform: uppercase; }
.text-success { color: #cba65f !important; }
.btn-primary { background: linear-gradient(180deg, #e0bf7c, #c9a35c); border: none; color: #1c1508; font-weight: 600; }
.btn-primary:hover { background: linear-gradient(180deg, #e8c988, #d3ad64); color: #1c1508; }
.btn-danger { background: transparent; border: 1px solid rgba(224,120,120,.5); color: #e8a0a0; }
.btn-danger:hover { background: rgba(224,120,120,.12); border-color: #e8a0a0; color: #f2b8b8; }
.btn-outline-dark { border: 1px solid rgba(203,166,95,.55); color: #cba65f; }
.btn-outline-dark:hover { background: rgba(214,179,106,.15); border-color: #cba65f; color: #e0bf7c; }
.badge.bg-primary { background: rgba(100,140,225,.18) !important; color: #a3bcf2; }
.badge.bg-success { background: rgba(110,200,140,.16) !important; color: #a2d9b4; }
.badge.bg-danger { background: rgba(214,179,106,.18) !important; color: #e0c993; }
.badge.bg-warning { background: rgba(214,179,106,.2) !important; }
.badge.bg-warning.text-dark { color: #e0c993 !important; }
/* ==== end overrides ==== */
</style>

<div class="bg-light min-vh-100 py-5">

    <div class="container">

        <!-- Title -->
        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>
                <h1 class="fw-bold text-dark mb-1">
                    <%= card.card_name %>
                </h1>

                <p class="text-secondary mb-0">
                    Card Details
                </p>
            </div>

            <div class="d-flex gap-2">

                <a href="/edit-card/<%= card.card_id %>" class="btn btn-primary">
                    Edit Card
                </a>

                <form action="/delete-card/<%= card.card_id %>"
                      method="POST"
                      onsubmit="return confirm('Are you sure you want to delete this card?');">

                    <button type="submit" class="btn btn-danger">
                        Delete Card
                    </button>

                </form>

            </div>

        </div>

        <div class="card border-0 shadow-lg rounded-4">

            <div class="card-body p-5">

                <div class="row align-items-center">

                    <!-- Image -->
                    <div class="col-md-5 text-center">

                        <img src="/images/<%= card.image %>"
                             alt="<%= card.card_name %>"
                             class="img-fluid rounded shadow"
                             style="max-height:500px; object-fit:contain;">

                    </div>

                    <!-- Details -->
                    <div class="col-md-7">

                        <h2 class="fw-bold mb-4 text-dark">
                            <%= card.card_name %>
                        </h2>

                        <table class="table table-borderless">

                            <tbody>

                                <tr>
                                    <th class="text-secondary" width="35%">Category</th>
                                    <td>
                                        <span class="badge bg-primary px-3 py-2">
                                            <%= card.category %>
                                        </span>
                                    </td>
                                </tr>

                                <tr>
                                    <th class="text-secondary">Condition</th>
                                    <td>
                                        <span class="badge bg-success px-3 py-2">
                                            <%= card.condition_name %>
                                        </span>
                                    </td>
                                </tr>

                                <tr>
                                    <th class="text-secondary">Rarity</th>
                                    <td>
                                        <span class="badge bg-danger px-3 py-2">
                                            <%= card.rarity %>
                                        </span>
                                    </td>
                                </tr>

                                <tr>
                                    <th class="text-secondary">Quantity</th>
                                    <td>
                                        <span class="badge bg-warning text-dark px-3 py-2">
                                            <%= card.quantity %>
                                        </span>
                                    </td>
                                </tr>

                                <tr>
                                    <th class="text-secondary">Estimated Value</th>
                                    <td class="fs-4 fw-bold text-success">
                                        $<%= Number(card.estimated_value).toFixed(2) %>
                                    </td>
                                </tr>

                                <tr>
                                    <th class="text-secondary">Remarks</th>
                                    <td>
                                        <%= card.remarks || "-" %>
                                    </td>
                                </tr>

                                <tr>
                                    <th class="text-secondary">Date Added</th>
                                    <td>
                                        <%= card.date_added %>
                                    </td>
                                </tr>

                            </tbody>

                        </table>

                        <div class="mt-4">

                            <a href="/dashboard" class="btn btn-outline-dark px-4">
                                ← Back to Collection
                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include('partials/footer') %>