<%- include('partials/header', { title: 'Remove Collection Goal - CardVault', user: user }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
body{
    background:#0a0c12;
    color:#d8dae0;
}

.container.my-5 h1{
    font-family:'Instrument Serif', Georgia, serif;
    font-size:3.25rem;
    font-weight:400;
    color:#f4f2ee;
    letter-spacing:-2px;
}

.goal-card{
    background:linear-gradient(160deg,#12151d 0%,#0d1016 100%);
    border:1px solid rgba(200,90,84,.35);
    border-radius:14px;
    box-shadow:0 18px 48px rgba(0,0,0,.55);
}

.goal-title{
    font-family:'Instrument Serif', Georgia, serif;
    font-size:2rem;
    color:#f4f2ee;
    margin-bottom:15px;
}

.text-muted{
    color:#9ca0ab !important;
}

.progress-text{
    color:#d8dae0;
}

.text-warning{
    color:#e0bf7c !important;
}

.warning-box{
    background:rgba(200,90,84,.08);
    border:1px solid rgba(200,90,84,.35);
    border-radius:10px;
    color:#f2b5b2;
    padding:15px;
    margin-top:25px;
    margin-bottom:30px;
}

.btn-delete{
    background:#c85a54;
    border:none;
    color:white;
    font-weight:600;
    padding:10px 22px;
}

.btn-delete:hover{
    background:#b84b45;
    color:white;
}

.btn-cancel{
    background:transparent;
    border:1px solid rgba(203,166,95,.45);
    color:#e0bf7c;
    font-weight:600;
    padding:10px 22px;
}

.btn-cancel:hover{
    background:rgba(203,166,95,.15);
    border-color:#cba65f;
    color:#f4f2ee;
}
</style>

<div class="container my-5" style="max-width:720px;">

    <div class="goal-card">

        <div class="card-body p-5">

            <h1 class="mb-4">
                Delete Collection Goal
            </h1>

            <h2 class="goal-title">
                <%= goal.goal_name %>
            </h2>

            <p class="text-muted">
                <%= goal.description %>
            </p>

            <hr class="border-secondary">

            <p class="progress-text">
                <strong class="text-warning">
                    Progress
                </strong>

                <br>

                <%= goal.current_cards %> /
                <%= goal.target_cards %> cards
            </p>

            <div class="warning-box">

                <strong>
                    ⚠ Warning
                </strong>

                <br><br>

                This action will permanently delete this collection goal.
                This cannot be undone.

            </div>

            <form action="/remove-goal/<%= goal.goal_id %>" method="POST">

                <button type="submit" class="btn btn-delete">
                    Delete Goal
                </button>

                <a href="/goals" class="btn btn-cancel ms-2">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>

<%- include('partials/footer') %>