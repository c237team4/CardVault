<%- include('partials/header', { title: 'Edit Collection Goal', user: user }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
body{
    background:#0a0c12;
    color:#d8dae0;
}

.goal-form{
    background:linear-gradient(160deg,#12151d 0%,#0d1016 100%);
    border:1px solid rgba(203,166,95,.28);
    border-radius:14px;
    box-shadow:0 18px 48px rgba(0,0,0,.55);
}

h1{
    font-family:'Instrument Serif',serif;
    font-size:3rem;
    color:#f4f2ee;
}

label{
    color:#e0bf7c;
    font-weight:600;
}

.form-control,
.form-select{
    background:#1b1e26;
    border:1px solid #3a3d45;
    color:white;
}

.form-control:focus,
.form-select:focus{
    background:#1b1e26;
    color:white;
    border-color:#cba65f;
    box-shadow:none;
}

.btn-gold{
    background:linear-gradient(180deg,#e0bf7c,#cba65f);
    color:#0a0c12;
    border:none;
    font-weight:600;
}

.btn-gold:hover{
    background:linear-gradient(180deg,#ecca88,#d9b46e);
    color:#0a0c12;
}

.btn-cancel{
    color:#e0bf7c;
    border:1px solid rgba(203,166,95,.5);
}

.btn-cancel:hover{
    background:rgba(203,166,95,.15);
    color:white;
}
</style>

<div class="container my-5" style="max-width:700px;">

<div class="goal-form p-5">

<h1 class="mb-4">Edit Collection Goal</h1>

<form action="/edit-goal/<%= goal.goal_id %>" method="POST">

<div class="mb-3">
<label>Goal Name</label>
<input type="text" class="form-control" name="goal_name" value="<%= goal.goal_name %>" required>
</div>

<div class="mb-3">
<label>Description</label>
<textarea class="form-control" rows="3" name="description"><%= goal.description %></textarea>
</div>

<div class="mb-3">
<label>Target Cards</label>
<input type="number" class="form-control" name="target_cards" value="<%= goal.target_cards %>" required>
</div>

<div class="mb-3">
<label>Current Cards</label>
<input type="number" class="form-control" name="current_cards" value="<%= goal.current_cards %>" required>
</div>

<div class="mb-4">
<label>Status</label>

<select class="form-select" name="status">
<option value="In Progress" <%= goal.status==="In Progress"?"selected":"" %>>In Progress</option>
<option value="Completed" <%= goal.status==="Completed"?"selected":"" %>>Completed</option>
</select>

</div>

<button class="btn btn-gold">Save Changes</button>

<a href="/goals" class="btn btn-cancel ms-2">Cancel</a>

</form>

</div>

</div>

<%- include('partials/footer') %>