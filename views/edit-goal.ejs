<%- include('partials/header', { title: 'Edit Goal - CardVault', user: user }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
body {
    background: #0a0c12;
    color: #d8dae0;
}

.container.my-5 h1 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 3.25rem;
    font-weight: 400;
    color: #f4f2ee;
    letter-spacing: -5px;
}

.container.my-5 .text-muted {
    color: #8b8f9a !important;
}

.card {
    background: linear-gradient(160deg, #12151d 0%, #0d1016 100%);
    border: 1px solid rgba(203,166,95,.28);
    border-radius: 14px;
    box-shadow: 0 18px 48px rgba(0,0,0,.55);
}

.form-label {
    color: #e0bf7c;
    font-weight: 600;
}

.form-control,
.form-select {
    background: #181c24;
    border: 1px solid rgba(203,166,95,.25);
    color: #f4f2ee;
}

.form-control:focus,
.form-select:focus {
    background: #181c24;
    color: #f4f2ee;
    border-color: #cba65f;
    box-shadow: 0 0 0 .2rem rgba(203,166,95,.15);
}

.form-control::placeholder {
    color: #8b8f9a;
}

.btn-success {
    background: linear-gradient(180deg,#e0bf7c,#cba65f);
    border: none;
    color: #0a0c12;
    font-weight: 600;
}

.btn-success:hover {
    background: linear-gradient(180deg,#ecca88,#d9b46e);
    color: #0a0c12;
}

.btn-secondary {
    background: transparent;
    border: 1px solid rgba(203,166,95,.45);
    color: #e0bf7c;
}

.btn-secondary:hover {
    background: rgba(203,166,95,.15);
    border-color: #cba65f;
    color: #f4f2ee;
}
</style>

<div class="container my-5">

    <div class="card">

        <div class="card-body p-5">

            <h1 class="mb-4">
                ✏️ Edit Collection Goal
            </h1>

            <form action="/edit-goal/<%= goal.goal_id %>" method="POST">

                <div class="mb-3">
                    <label class="form-label">Goal Name</label>

                    <input
                        type="text"
                        name="goal_name"
                        class="form-control"
                        value="<%= goal.goal_name %>"
                        required>
                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Description
                    </label>

                    <textarea
                        name="description"
                        class="form-control"
                        rows="4"><%= goal.description %></textarea>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Target Number of Cards
                    </label>

                    <input
                        type="number"
                        name="target_cards"
                        class="form-control"
                        min="1"
                        value="<%= goal.target_cards %>"
                        required>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Current Cards Collected
                    </label>

                    <input
                        type="number"
                        name="current_cards"
                        class="form-control"
                        min="0"
                        value="<%= goal.current_cards %>"
                        required>

                </div>

                <div class="mb-4">

                    <label class="form-label">
                        Status
                    </label>

                    <select name="status" class="form-select">

                        <option value="In Progress"
                            <%= goal.status === "In Progress" ? "selected" : "" %>>
                            In Progress
                        </option>

                        <option value="Completed"
                            <%= goal.status === "Completed" ? "selected" : "" %>>
                            Completed
                        </option>

                    </select>

                </div>

                <button class="btn btn-success">
                    Save Changes
                </button>

                <a href="/goals" class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>

<%- include('partials/footer') %>