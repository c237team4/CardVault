<%- include('partials/header', { title: 'Register - CardVault' }) %>

<!-- ============================================================
     REGISTER  |  Owner: Tan Boon Meng (25052694)
     Renders with: messages (flash error), formData (sticky form)
     Posts to: POST /register
     ============================================================ -->

<div class="row justify-content-center">
  <div class="col-md-5">

    <h2 class="mb-3">Create your account</h2>

    <%# Show any validation errors the register route flashed back %>
    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-danger">
        <% messages.forEach(msg => { %>
          <div><%= msg %></div>
        <% }) %>
      </div>
    <% } %>

    <form action="/register" method="POST">

      <%# value=... re-fills the form after a failed attempt, so the user does
          not have to retype everything. formData is undefined on first load,
          hence the guard. %>
      <div class="mb-3">
        <label class="form-label" for="username">Username</label>
        <input class="form-control" type="text" id="username" name="username"
               value="<%= formData ? formData.username : '' %>" required>
      </div>

      <div class="mb-3">
        <label class="form-label" for="email">Email</label>
        <input class="form-control" type="email" id="email" name="email"
               value="<%= formData ? formData.email : '' %>" required>
      </div>

      <div class="mb-3">
        <label class="form-label" for="password">Password</label>
        <input class="form-control" type="password" id="password" name="password"
               minlength="6" required>
        <div class="form-text">At least 6 characters.</div>
      </div>

      <%# No role field on purpose. If the user could choose their own role,
          anyone could register as an admin. New accounts default to 'user'
          in the database; admins are seeded in cardvault.sql. %>

      <button class="btn btn-primary w-100" type="submit">Register</button>
    </form>

    <p class="mt-3 mb-0">Already have an account? <a href="/login">Log in</a></p>

  </div>
</div>

<%- include('partials/footer') %>
