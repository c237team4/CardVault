<%- include('partials/header', { title: 'Register - CardVault' }) %>

<div class="container mt-4">
    <h1>Register</h1>

    <%# Step 2b - Show error message %>

    <% if (messages && messages.length > 0) { %>
        <div class="alert alert-danger">
            <% messages.forEach(function(message) { %>
                <p><%= message %></p>
            <% }); %>
        </div>
    <% } %>


    <%# Step 2a - Registration form creation %>


    <form action="/register" method="POST" class="mt-4">
        <div class="form-group mb-3">
            <label for="username">Username:</label>
            <input type="text" id="username" name="username" class="form-control" required
                <% if (formData && formData.username) { %> value="<%= formData.username %>" <% } else { %> value="" <% } %>>
        </div>

        <div class="form-group mb-3">
            <label for="email">Email:</label>
            <input type="email" id="email" name="email" class="form-control" required
                <% if (formData && formData.email) { %> value="<%= formData.email %>" <% } else { %> value="" <% } %>>
        </div>

        <div class="form-group mb-3">
            <label for="password">Password:</label>
            <input type="password" id="password" name="password" class="form-control" required>
        </div>

        <button type="submit" class="btn btn-primary">Register</button>
    </form>
</div>


<%- include('partials/footer') %>
