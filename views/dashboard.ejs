<%- include('partials/header', { title: 'My Collection - CardVault' }) %>

<div class="bg-light min-vh-100 py-5">

    <div class="container">

        <!-- Page Title -->
        <div class="text-center mb-5">

            <h1 class="fw-bold">Card Collection</h1>

            <p class="text-muted">
                View your personal card collection.
            </p>

        </div>

        <!-- Search & Filter -->
        <div class="card shadow-sm mb-4">

            <div class="card-body">

                <form action="/search" method="GET">

                    <div class="row g-3">

                        <!-- Search -->
                        <div class="col-md-5">

                            <input
                                type="text"
                                name="search"
                                class="form-control"
                                placeholder="Search by card name"
                                value="<%= typeof search !== 'undefined' ? search : '' %>">

                        </div>

                        <!-- Category -->
                        <div class="col-md-5">

                            <select name="category" class="form-select">

                                <option value="">All Categories</option>

                                <% if (typeof categories !== 'undefined') { %>

                                    <% categories.forEach(category => { %>

                                        <option
                                            value="<%= category.category %>"
                                            <%= categoryFilter === category.category ? 'selected' : '' %>>

                                            <%= category.category %>

                                        </option>

                                    <% }) %>

                                <% } %>

                            </select>

                        </div>

                        <!-- Button -->
                        <div class="col-md-2 d-grid">

                            <button type="submit" class="btn btn-dark">

                                Search

                            </button>

                        </div>

                    </div>

                </form>

            </div>

        </div>

        <% if(cards.length > 0){ %>

            <div class="row g-4">

                <% cards.forEach(card => { %>

                    <div class="col-lg-4 col-md-6">

                        <div class="card shadow-sm h-100 border">

                            <!-- Card Image -->
                            <div class="text-center pt-4">

                                <img
                                    src="/images/<%= card.image %>"
                                    alt="<%= card.card_name %>"
                                    style="height:280px; object-fit:contain; max-width:100%;">

                            </div>

                            <!-- Card Body -->
                            <div class="card-body d-flex flex-column">

                                <h2 class="text-center fw-bold mb-4">

                                    <%= card.card_name %>

                                </h2>

                                <hr>

                                <div class="mt-auto">

                                    <div class="d-grid">

                                        <a href="/card/<%= card.card_id %>" class="btn btn-dark">

                                            View Details

                                        </a>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                <% }) %>

            </div>

        <% } else { %>

            <div class="card shadow border-0">

                <div class="card-body text-center py-5">

                    <h4>No cards found.</h4>

                    <p class="text-muted">

                        Try changing your search or filter.

                    </p>

                </div>

            </div>

        <% } %>

    </div>

</div>

<%- include('partials/footer') %>