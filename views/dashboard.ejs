<%- include('partials/header', { title: 'My Collection - CardVault' }) %>

<div class="bg-light min-vh-100 py-5">

    <div class="container">

        <!-- Page Title -->
        <div class="text-center mb-5">

            <h1 class="fw-bold">Card Collection</h1>

            <p class="text-muted">
                View your personal card collection.
            </p>

            <a href="/add-card" class="btn btn-success btn-lg mb-3"> + Add New Card </a>

        </div>

        <!-- Search & Filter -->
        <div class="card shadow-sm mb-4">

            <div class="card-body">

                <form action="/search" method="GET">

                    <div class="row g-3">


                        <!-- Search -->
                        <div class="col-md-5">

                            <input
                                type="text"
                                name="search"
                                class="form-control"
                                placeholder="Search by card name"
                                value="<%= typeof search !== 'undefined' ? search : '' %>">

                        </div>


                        <!-- Category -->
                        <div class="col-md-5">

                            <select name="category" class="form-select">

                                <option value="">
                                    All Categories
                                </option>


                                <% if (typeof categories !== 'undefined') { %>

                                    <% categories.forEach(category => { %>

                                        <option
                                            value="<%= category.category %>"
                                            <%= categoryFilter === category.category ? 'selected' : '' %>>

                                            <%= category.category %>

                                        </option>

                                    <% }) %>

                                <% } %>


                            </select>

                        </div>


                        <!-- Button -->
                        <div class="col-md-2 d-grid">

                            <button type="submit" class="btn btn-dark">

                                Search
                            </button>
                        </div>


                    </div>

                </form>

            </div>

        </div>




        <% if(cards.length > 0){ %>


        <div class="row g-4">


            <% cards.forEach(card => { %>


            <div class="col-lg-4 col-md-6">


                <div class="card shadow-sm h-100 border-0 rounded-4 overflow-hidden">


                    <!-- Card Image -->

                    <div class="text-center p-4 bg-white">

                        <img
                            src="/images/<%= card.image %>"
                            alt="<%= card.card_name %>"
                            style="
                                height:280px;
                                width:100%;
                                object-fit:contain;
                            ">

                    </div>




                    <!-- Card Body -->

                    <div class="card-body">


                        <h2 class="text-center fw-bold mb-3">

                            <%= card.card_name %>

                        </h2>


                        <hr>




                        <!-- Card Information -->

                        <div class="mb-4">


                            <!-- Category -->

                            <div class="mb-3">

                                <span class="badge bg-primary px-3 py-2">

                                    Category

                                </span>


                                <span class="badge bg-primary ms-2 px-3 py-2">

                                    <%= card.category %>

                                </span>

                            </div>





                            <!-- Rarity -->

                            <div class="mb-3">

                                <span class="badge bg-danger px-3 py-2">

                                    Rarity

                                </span>


                                <span class="badge bg-danger ms-2 px-3 py-2">

                                    <%= card.rarity %>

                                </span>

                            </div>





                            <!-- Condition -->

                            <div class="mb-3">

                                <span class="badge bg-success px-3 py-2">

                                    Condition

                                </span>


                                <span class="badge bg-success ms-2 px-3 py-2">

                                    <%= card.condition_name %>

                                </span>

                            </div>





                            <!-- Value -->

                            <div class="mb-3">

                                <span class="badge bg-info px-3 py-2">

                                    Value

                                </span>


                                <span class="badge bg-info ms-2 px-3 py-2">

                                    $<%= Number(card.estimated_value).toFixed(2) %>

                                </span>

                            </div>



                        </div>





                        <!-- View / Edit Buttons -->

                        <div class="d-grid gap-2">


                            <a href="/card/<%= card.card_id %>"
                               class="btn btn-dark rounded-pill">

                                View Details

                            </a>

                            <a href="/edit-card/<%= card.card_id %>"
                               class="btn btn-outline-primary rounded-pill">

                                Edit Card

                            </a>


                        </div>



                    </div>



                </div>



            </div>



            <% }) %>


        </div>




        <% } else { %>



        <div class="card shadow border-0">


            <div class="card-body text-center py-5">


                <h4>
                    No cards found.
                </h4>


                <p class="text-muted">

                    Try changing your search or filter.

                </p>


            </div>


        </div>



        <% } %>



    </div>


</div>


<%- include('partials/footer') %>
