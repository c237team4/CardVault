<%- include('partials/header', { title: 'My Collection - CardVault' }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ==== CardVault dark vault theme — styling overrides only ==== */
body { background: #0a0c12; font-family: Archivo, system-ui, sans-serif; }
.bg-light { background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%) !important; }
h1, h2, .display-4 { font-family: 'Instrument Serif', serif; font-weight: 400 !important; color: #f2ede1; }
h2 { font-size: 30px; }
h4 { color: #f2ede1; }
.text-muted { color: #8a90a4 !important; }
.card { background: #12151e; border: 1px solid rgba(203,166,95,.25) !important; }
.shadow, .shadow-sm { box-shadow: 0 20px 50px rgba(0,0,0,.45) !important; }
.card-body { color: #d8dce8; }
.card hr { border-color: rgba(203,166,95,.35); opacity: 1; }
.card .bg-white { background: #171c28 !important; }
.form-control, .form-select { background-color: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.14); color: #f2ede1; }
.form-control:focus, .form-select:focus { background-color: rgba(255,255,255,.04); border-color: rgba(203,166,95,.7); color: #f2ede1; box-shadow: 0 0 0 .25rem rgba(203,166,95,.15); }
.form-control::placeholder { color: #5a6175; }
.form-select option { background: #12151e; color: #f2ede1; }
.btn-dark { background: linear-gradient(180deg, #e0bf7c, #c9a35c); border: none; color: #1c1508; font-weight: 600; }
.btn-dark:hover { background: linear-gradient(180deg, #e8c988, #d3ad64); color: #1c1508; }
.badge.bg-primary { background: rgba(100,140,225,.18) !important; color: #a3bcf2; }
.badge.bg-danger { background: rgba(214,179,106,.18) !important; color: #e0c993; }
.badge.bg-success { background: rgba(110,200,140,.16) !important; color: #a2d9b4; }
.badge.bg-info { background: rgba(120,195,220,.16) !important; color: #a8d9e8; }
/* ==== end overrides ==== */
</style>





<div class="bg-light min-vh-100 py-5">

    <div class="container">

        <!-- Page Title -->
        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>
                <h1 class="fw-bold mb-1">Card Collection</h1>

                <p class="text-muted mb-0">
                    View your personal card collection.
                </p>
            </div>

            <a href="/add-card" class="btn btn-success">
                + Add New Card
            </a>

        </div>

<!-- Search & Filter -->
<div class="card shadow-sm mb-4">

    <div class="card-body">

        <form action="/search" method="GET">

            <div class="row g-3">

                <!-- Search -->
                <div class="col-md-4">

                    <input
                        type="text"
                        name="search"
                        class="form-control"
                        placeholder="Search by card name"
                        value="<%= typeof search !== 'undefined' ? search : '' %>">

                </div>


                <!-- Category -->
                <div class="col-md-3">

                    <select name="category" class="form-select">

                        <option value="">
                            All Categories
                        </option>

                        <% if (typeof categories !== 'undefined') { %>

                            <% categories.forEach(category => { %>

                                <option
                                    value="<%= category.category %>"
                                    <%= categoryFilter === category.category ? 'selected' : '' %>>

                                    <%= category.category %>

                                </option>

                            <% }) %>

                        <% } %>

                    </select>

                </div>


                <!-- Rarity -->
                <div class="col-md-3">

                    <select name="rarity" class="form-select">

                        <option value="">
                            All Rarities
                        </option>

                        <% if (typeof rarities !== 'undefined') { %>

                            <% rarities.forEach(rarity => { %>

                                <option
                                    value="<%= rarity.rarity %>"
                                    <%= rarityFilter === rarity.rarity ? 'selected' : '' %>>

                                    <%= rarity.rarity %>

                                </option>

                            <% }) %>

                        <% } %>

                    </select>

                </div>


                <!-- Button -->
                <div class="col-md-2 d-grid">

                    <button type="submit" class="btn btn-dark">
                        Search
                    </button>

                </div>

            </div>

        </form>

    </div>

</div>

        <% if(cards.length > 0){ %>

        <div class="row g-4">

            <% cards.forEach(card => { %>

            <div class="col-lg-4 col-md-6">

                <div class="card shadow-sm h-100 border-0 rounded-4 overflow-hidden">

                    <!-- Card Image -->
                    <div class="text-center p-4 bg-white">

                        <img
                            src="/images/<%= card.image %>"
                            alt="<%= card.card_name %>"
                            style="
                                height:280px;
                                width:100%;
                                object-fit:contain;
                            ">

                    </div>

                    <!-- Card Body -->
                    <div class="card-body">

                        <h2 class="text-center fw-bold mb-3">

                            <%= card.card_name %>

                        </h2>

                        <hr>

                        <!-- Card Information -->
                        <div class="mb-4">

                            <!-- Category -->
                            <div class="mb-3">

                                <span class="badge bg-primary px-3 py-2">
                                    Category
                                </span>

                                <span class="badge bg-primary ms-2 px-3 py-2">
                                    <%= card.category %>
                                </span>

                            </div>

                            <!-- Rarity -->
                            <div class="mb-3">

                                <span class="badge bg-danger px-3 py-2">
                                    Rarity
                                </span>

                                <span class="badge bg-danger ms-2 px-3 py-2">
                                    <%= card.rarity %>
                                </span>

                            </div>

                            <!-- Condition -->
                            <div class="mb-3">

                                <span class="badge bg-success px-3 py-2">
                                    Condition
                                </span>

                                <span class="badge bg-success ms-2 px-3 py-2">
                                    <%= card.condition_name %>
                                </span>

                            </div>

                            <!-- Value -->
                            <div class="mb-3">

                                <span class="badge bg-info px-3 py-2">
                                    Value
                                </span>

                                <span class="badge bg-info ms-2 px-3 py-2">
                                    $<%= Number(card.estimated_value).toFixed(2) %>
                                </span>

                            </div>

                        </div>

                        <!-- View Button -->
                        <div class="d-grid">

                            <a href="/card/<%= card.card_id %>"
                               class="btn btn-dark rounded-pill">
                                View Details
                            </a>

                        </div>

                    </div>

                </div>

            </div>

            <% }) %>

        </div>

        <% } else { %>

        <div class="card shadow border-0">

            <div class="card-body text-center py-5">

                <h4>
                    No cards found.
                </h4>

                <p class="text-muted">
                    Try changing your search or filter.
                </p>

            </div>

        </div>

        <% } %>

    </div>

</div>

<%- include('partials/footer') %>