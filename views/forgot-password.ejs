<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CardVault &mdash; Reset your password</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  html, body { height: 100%; margin: 0; }
  body { background: #0a0c12; font-family: Archivo, system-ui, sans-serif;
         display: flex; align-items: center; justify-content: center; min-height: 100vh; }
  a { color: #cba65f; text-decoration: none; }
  a:hover { color: #e0bf7c; }
  input::placeholder { color: #5a6175; }
  .field { display: flex; flex-direction: column; gap: 7px; margin-bottom: 16px; }
  .field label { font: 600 11px ui-monospace, Menlo, monospace; letter-spacing: .2em; color: #8a90a4; }
  .field input { padding: 14px 16px; background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.14); border-radius: 8px;
    color: #f2ede1; font: 400 15px Archivo, sans-serif; outline: none; }
  .field input:focus { border-color: rgba(203,166,95,.7); }
  .btn-submit { padding: 16px; width: 100%;
    background: linear-gradient(180deg, #e0bf7c, #c9a35c);
    color: #1c1508; font: 600 16px Archivo, sans-serif;
    border: none; border-radius: 8px; cursor: pointer; }
  .btn-submit:hover { filter: brightness(1.06); }
</style>
</head>
<body>
  <div style="width:400px;padding:40px;box-sizing:border-box">
    <span style="font:600 11.5px ui-monospace,Menlo,monospace;letter-spacing:.3em;color:#cba65f">FORGOT YOUR KEY?</span>
    <h1 style="margin:8px 0 20px;font:400 40px/1.08 'Instrument Serif',serif;color:#f2ede1">Reset your password.</h1>

    <% if (errors && errors.length > 0) { %>
      <div style="padding:13px 16px;margin-bottom:16px;border:1px solid rgba(224,120,120,.45);background:rgba(224,120,120,.08);border-radius:8px;font:400 14px Archivo,sans-serif;color:#e8a0a0">
        <%= errors[0] %>
      </div>
    <% } %>

    <form action="/forgot-password" method="POST">
      <div class="field">
        <label for="email">EMAIL</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required>
      </div>
      <div class="field">
        <label for="password">NEW PASSWORD</label>
        <input type="password" id="password" name="password" placeholder="At least 6 characters" required>
      </div>
      <button type="submit" class="btn-submit">Reset password</button>
    </form>

    <p style="margin-top:16px;font:400 14px Archivo,sans-serif;color:#8a90a4">Remembered it? <a href="/login">Back to login</a></p>
  </div>
</body>
</html>