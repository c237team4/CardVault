<%- include('partials/header', { title: 'Card Details - CardVault' }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ==== CardVault dark vault theme — styling overrides only ==== */
body { background: #0a0c12; font-family: Archivo, system-ui, sans-serif; }
.bg-light { background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%) !important; }
h1, h2, h5 { font-family: 'Instrument Serif', serif; font-weight: 400 !important; color: #f2ede1; }
.text-muted { color: #8a90a4 !important; }
.card { background: #12151e; border: 1px solid rgba(203,166,95,.25) !important; }
.shadow { box-shadow: 0 24px 60px rgba(0,0,0,.55) !important; }
.card-body { color: #d8dce8; }
.card-body .fw-bold { color: #f2ede1; }
.card .col-md-5.bg-white { background: #171c28 !important; }
.card-body img.shadow-sm { box-shadow: 0 20px 50px rgba(0,0,0,.6) !important; }
.card-body .bg-light { background: #171c28 !important; }
.btn-secondary { background: transparent; border: 1px solid rgba(203,166,95,.5); color: #cba65f; }
.btn-secondary:hover { background: rgba(214,179,106,.15); border-color: #cba65f; color: #e0bf7c; }
.badge.bg-primary { background: rgba(100,140,225,.18) !important; color: #a3bcf2; }
.badge.bg-danger { background: rgba(214,179,106,.18) !important; color: #e0c993; }
.badge.bg-success { background: rgba(110,200,140,.16) !important; color: #a2d9b4; }
.badge.bg-info { background: rgba(120,195,220,.16) !important; color: #a8d9e8; }
/* ==== end overrides ==== */
</style>


<div class="bg-light min-vh-100 py-5">

    <div class="container">


        <!-- Header -->

        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>

                <h1 class="fw-bold">
                    Card Details
                </h1>

                <p class="text-muted">
                    View complete information about this card.
                </p>

            </div>


            <a href="/admin/all-cards" class="btn btn-secondary rounded-pill px-4">

                Back to All Cards

            </a>

        </div>





        <!-- Card Details -->

        <div class="card shadow border-0 rounded-4 overflow-hidden">


            <div class="row g-0">



                <!-- Image Section -->

                <div class="col-md-5 bg-white d-flex align-items-center justify-content-center p-5">


                    <% if(card.image){ %>


                        <img src="/images/<%= card.image %>"
                             class="img-fluid rounded-4 shadow-sm"
                             style="height:380px; object-fit:contain;">


                    <% } else { %>


                        <div class="text-muted">

                            No Image Available

                        </div>


                    <% } %>


                </div>






                <!-- Information Section -->

                <div class="col-md-7">


                    <div class="card-body p-5">



                        <h2 class="fw-bold mb-4">

                            <%= card.card_name %>

                        </h2>





                        <!-- Owner -->

                        <div class="mb-3">

                            <span class="fw-bold">
                                Owner:
                            </span>

                            <span class="text-muted">
                                <%= card.username %>
                            </span>

                        </div>






                        <!-- Category -->

                        <div class="mb-3">

                            <span class="badge bg-primary px-3 py-2">

                                Category

                            </span>


                            <span class="badge bg-primary px-3 py-2 ms-2">

                                <%= card.category %>

                            </span>


                        </div>






                        <!-- Rarity -->

                        <div class="mb-3">

                            <span class="badge bg-danger px-3 py-2">

                                Rarity

                            </span>


                            <span class="badge bg-danger px-3 py-2 ms-2">

                                <%= card.rarity %>

                            </span>


                        </div>






                        <!-- Condition -->

                        <div class="mb-3">

                            <span class="badge bg-success px-3 py-2">

                                Condition

                            </span>


                            <span class="badge bg-success px-3 py-2 ms-2">

                                <%= card.condition_name %>

                            </span>


                        </div>






                        <!-- Value -->

                        <div class="mb-3">

                            <span class="badge bg-info px-3 py-2">

                                Value

                            </span>


                            <span class="badge bg-info px-3 py-2 ms-2">

                                $<%= card.estimated_value %>

                            </span>


                        </div>






                        <!-- Quantity -->

                        <div class="mb-3">

                            <span class="fw-bold">

                                Quantity:

                            </span>


                            <span class="text-muted">

                                <%= card.quantity %>

                            </span>


                        </div>






                        <!-- Remarks -->

                        <div class="mt-4">


                            <h5 class="fw-bold">

                                Remarks

                            </h5>


                            <div class="bg-light rounded-3 p-3 text-muted">

                                <%= card.remarks || 'No remarks added.' %>

                            </div>


                        </div>




                    </div>


                </div>



            </div>


        </div>




    </div>


</div>


<%- include('partials/footer') %>