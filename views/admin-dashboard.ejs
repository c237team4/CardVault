<%- include('partials/header', { title: 'Admin Dashboard - CardVault' }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ==== CardVault dark vault theme — styling overrides only ==== */
body { background: #0a0c12; font-family: Archivo, system-ui, sans-serif; }
.bg-light { background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%) !important; }
h1, .display-4 { font-family: 'Instrument Serif', serif; font-weight: 400 !important; color: #f2ede1; }
.text-muted { color: #8a90a4 !important; }
.card { background: #12151e; border: 1px solid rgba(203,166,95,.25) !important; }
.shadow { box-shadow: 0 20px 50px rgba(0,0,0,.45) !important; }
.card-header.bg-dark { background: #0d1017 !important; border-bottom: 1px solid rgba(203,166,95,.25); }
.card-header h4 { font-family: 'Instrument Serif', serif; font-weight: 400; color: #f2ede1; letter-spacing: .02em; }
.card-body h5.text-secondary { color: #cba65f !important; font: 600 12px Archivo, sans-serif; letter-spacing: .3em; text-transform: uppercase; }
.display-4 { color: #cba65f; }
.table { color: #d8dce8; }
.table > :not(caption) > * > * { background: transparent; color: #d8dce8; border-bottom-color: rgba(255,255,255,.08); }
.table thead.table-light th { background: #171c28 !important; color: #cba65f !important; font: 600 12px Archivo, sans-serif; letter-spacing: .12em; text-transform: uppercase; border-bottom-color: rgba(203,166,95,.3) !important; }
.table-hover > tbody > tr:hover > * { background: rgba(214,179,106,.06); color: #f2ede1; }
.btn-success { background: linear-gradient(180deg, #e0bf7c, #c9a35c); border: none; color: #1c1508; font-weight: 600; }
.btn-success:hover { background: linear-gradient(180deg, #e8c988, #d3ad64); color: #1c1508; }
.btn-primary { background: transparent; border: 1px solid rgba(203,166,95,.55); color: #cba65f; }
.btn-primary:hover { background: rgba(214,179,106,.15); border-color: #cba65f; color: #e0bf7c; }
.btn-warning { background: #7d5f2a; border: none; }
.btn-warning:hover { background: #94722f; }
.badge.bg-danger { background: linear-gradient(180deg, #e0bf7c, #c9a35c) !important; color: #1c1508; }
.badge.bg-secondary { background: rgba(255,255,255,.12) !important; color: #aab0c0; }
/* ==== end overrides ==== */
</style>




<div class="bg-light min-vh-100 py-5">

    <div class="container">

        <!-- Page Title -->
        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>

                <h1 class="fw-bold mb-1">
                    Admin Dashboard
                </h1>

                <p class="text-muted mb-0">
                    View registered users and monitor the CardVault system.
                </p>

            </div>

            <div class="d-flex gap-2">
                <a href="/meetups" class="btn btn-primary">Manage Meetups</a>
                <a href="/admin/all-cards" class="btn btn-success">View All Cards</a>
            </div>

        </div>

        <!-- Statistics -->
        <div class="row mb-5">

            <div class="col-md-6 mb-3">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <h5 class="text-secondary">Total Users</h5>

                        <h1 class="display-4 fw-bold">
                            <%= totalUsers %>
                        </h1>

                    </div>

                </div>

            </div>

            <div class="col-md-6 mb-3">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <h5 class="text-secondary">Total Cards</h5>

                        <h1 class="display-4 fw-bold">
                            <%= totalCards %>
                        </h1>

                    </div>

                </div>

            </div>

        </div>

        <!-- Registered Users -->
        <div class="card shadow border-0">

            <div class="card-header bg-dark text-white">

                <h4 class="mb-0">Registered Users</h4>

            </div>

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-light">

                            <tr>
                                <th>User ID</th>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Date Joined</th>
                                <th class="text-center">Action</th>
                            </tr>

                        </thead>

                        <tbody>

                            <% if(users.length > 0){ %>

                                <% users.forEach(user => { %>

                                    <tr>

                                        <td><%= user.user_id %></td>

                                        <td>
                                            <strong><%= user.username %></strong>
                                        </td>

                                        <td><%= user.email %></td>

                                        <td>

                                            <% if(user.role === 'admin'){ %>

                                                <span class="badge bg-danger">
                                                    Admin
                                                </span>

                                            <% } else { %>

                                                <span class="badge bg-secondary">
                                                    User
                                                </span>

                                            <% } %>

                                        </td>

                                        <td><%= user.date_joined %></td>

                                        <td class="text-center">

                                        <a href="/admin/user/<%= user.user_id %>" class="btn btn-primary btn-sm me-2">View Collection</a>

                                        <a href="/admin/edit-role/<%= user.user_id %>" class="btn btn-warning btn-sm text-white">Edit Role</a>
                                        </td>

                                    </tr>

                                <% }) %>

                            <% } else { %>

                                <tr>

                                    <td colspan="6" class="text-center py-4">

                                        No registered users found.

                                    </td>

                                </tr>

                            <% } %>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include('partials/footer') %>