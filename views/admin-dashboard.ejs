<%- include('partials/header', { title: 'Admin Dashboard - CardVault' }) %>

<div class="bg-light min-vh-100 py-5">

    <div class="container">

        <!-- Page Title -->
        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>

                <h1 class="fw-bold mb-1">
                    Admin Dashboard
                </h1>

                <p class="text-muted mb-0">
                    View registered users and monitor the CardVault system.
                </p>

            </div>

            <a href="/admin/all-cards" class="btn btn-success">

                View All Cards

            </a>

        </div>

        <!-- Statistics -->
        <div class="row mb-5">

            <div class="col-md-6 mb-3">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <h5 class="text-secondary">Total Users</h5>

                        <h1 class="display-4 fw-bold">
                            <%= totalUsers %>
                        </h1>

                    </div>

                </div>

            </div>

            <div class="col-md-6 mb-3">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <h5 class="text-secondary">Total Cards</h5>

                        <h1 class="display-4 fw-bold">
                            <%= totalCards %>
                        </h1>

                    </div>

                </div>

            </div>

        </div>

        <!-- Registered Users -->
        <div class="card shadow border-0">

            <div class="card-header bg-dark text-white">

                <h4 class="mb-0">Registered Users</h4>

            </div>

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-light">

                            <tr>
                                <th>User ID</th>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Date Joined</th>
                                <th class="text-center">Action</th>
                            </tr>

                        </thead>

                        <tbody>

                            <% if(users.length > 0){ %>

                                <% users.forEach(user => { %>

                                    <tr>

                                        <td><%= user.user_id %></td>

                                        <td>
                                            <strong><%= user.username %></strong>
                                        </td>

                                        <td><%= user.email %></td>

                                        <td>

                                            <% if(user.role === 'admin'){ %>

                                                <span class="badge bg-danger">
                                                    Admin
                                                </span>

                                            <% } else { %>

                                                <span class="badge bg-secondary">
                                                    User
                                                </span>

                                            <% } %>

                                        </td>

                                        <td><%= user.date_joined %></td>

                                        <td class="text-center">

                                        <a href="/admin/user/<%= user.user_id %>" class="btn btn-primary btn-sm me-2">View Collection</a>

                                        <a href="/admin/edit-role/<%= user.user_id %>" class="btn btn-warning btn-sm text-white">Edit Role</a>
                                        </td>

                                    </tr>

                                <% }) %>

                            <% } else { %>

                                <tr>

                                    <td colspan="6" class="text-center py-4">

                                        No registered users found.

                                    </td>

                                </tr>

                            <% } %>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include('partials/footer') %>