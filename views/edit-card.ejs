<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CardVault - Edit Card</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #0a0c12;
            background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%);
            font-family: Archivo, system-ui, sans-serif;
        }

        .form-card {
            background: #12151e;
            border: 1px solid rgba(203, 166, 95, .25);
            border-radius: 12px;
            box-shadow: 0 24px 60px rgba(0, 0, 0, .55);
            padding: 2.5rem;
        }

        /* ==== CardVault dark vault theme ==== */
        h2 { font-family: 'Instrument Serif', serif; font-weight: 400 !important; color: #f2ede1; }
        .text-muted { color: #8a90a4 !important; }
        .form-card hr { border-color: rgba(203,166,95,.35); opacity: 1; }
        .form-label { color: #d8dce8; }
        .form-control, .form-select { background-color: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.14); color: #f2ede1; }
        .form-control:focus, .form-select:focus { background-color: rgba(255,255,255,.04); border-color: rgba(203,166,95,.7); color: #f2ede1; box-shadow: 0 0 0 .25rem rgba(203,166,95,.15); }
        .form-select option { background: #12151e; color: #f2ede1; }
        .form-control[type=file]::file-selector-button { background: rgba(214,179,106,.15); border: none; color: #cba65f; }
        .alert-danger { background: rgba(224,120,120,.08); border: 1px solid rgba(224,120,120,.45); color: #e8a0a0; }
        .btn-primary { background: linear-gradient(180deg, #e0bf7c, #c9a35c); border: none; color: #1c1508; font-weight: 600; }
        .btn-primary:hover { background: linear-gradient(180deg, #e8c988, #d3ad64); color: #1c1508; }
        .btn-secondary { background: transparent; border: 1px solid rgba(255,255,255,.24); color: #e8e4d8; }
        .btn-secondary:hover { background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.5); color: #fff; }
    </style>
</head>

<body>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-7">

            <div class="form-card">
                <h2 class="fw-bold text-center mb-2">Edit Card</h2>
                <p class="text-muted text-center mb-4">
                    Update the details of this card in your vault collection.
                </p>
                <hr class="mb-4">

                <% if (messages && messages.length > 0) { %>
                    <div class="alert alert-danger">
                        <% messages.forEach(function(msg) { %>
                            <div><%= msg %></div>
                        <% }); %>
                    </div>
                <% } %>

                <form action="/edit-card/<%= card.card_id %>"
                      method="POST"
                      enctype="multipart/form-data"
                      onsubmit="return confirmSave()">

                    <!-- Hidden field to preserve the current image if no new one is uploaded -->
                    <input type="hidden" name="existing_image" value="<%= card.image %>">

                    <!-- Card Name -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Card Name</label>
                        <input type="text" class="form-control" name="card_name"
                            value="<%= card.card_name %>" required>
                    </div>

                    <!-- Genre & Condition -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Genre</label>
                            <select class="form-select" name="genre_id" required>
                                <option value="" disabled>Select Genre</option>
                                <option value="1" <%= card.genre_id == 1 ? 'selected' : '' %>>Trading Card Games</option>
                                <option value="2" <%= card.genre_id == 2 ? 'selected' : '' %>>Sport Cards</option>
                                <option value="3" <%= card.genre_id == 3 ? 'selected' : '' %>>Others</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Condition</label>
                            <select class="form-select" name="condition_id" required>
                                <option value="" disabled>Select Condition</option>
                                <option value="1" <%= card.condition_id == 1 ? 'selected' : '' %>>Mint</option>
                                <option value="2" <%= card.condition_id == 2 ? 'selected' : '' %>>Near Mint</option>
                                <option value="3" <%= card.condition_id == 3 ? 'selected' : '' %>>Excellent</option>
                                <option value="4" <%= card.condition_id == 4 ? 'selected' : '' %>>Good</option>
                                <option value="5" <%= card.condition_id == 5 ? 'selected' : '' %>>Played</option>
                                <option value="6" <%= card.condition_id == 6 ? 'selected' : '' %>>Poor</option>
                            </select>
                        </div>
                    </div>

                    <!-- Category & Rarity -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Category / Franchise</label>
                            <select class="form-select" name="category" required>
                                <option value="" disabled>Select Category</option>
                                <option <%= card.category === 'digimon' ? 'selected' : '' %>>digimon</option>
                                <option <%= card.category === 'football' ? 'selected' : '' %>>football</option>
                                <option <%= card.category === 'formula 1' ? 'selected' : '' %>>formula 1</option>
                                <option <%= card.category === 'NBA' ? 'selected' : '' %>>NBA</option>
                                <option <%= card.category === 'One Piece' ? 'selected' : '' %>>One Piece</option>
                                <option <%= card.category === 'Pokemon' ? 'selected' : '' %>>Pokemon</option>
                                <option <%= card.category === 'Yu-Gi-Oh!' ? 'selected' : '' %>>Yu-Gi-Oh!</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Rarity</label>
                            <select class="form-select" name="rarity" required>
                                <option value="" disabled>Select Rarity</option>
                                <option <%= card.rarity === 'Common' ? 'selected' : '' %>>Common</option>
                                <option <%= card.rarity === 'Uncommon' ? 'selected' : '' %>>Uncommon</option>
                                <option <%= card.rarity === 'Rare' ? 'selected' : '' %>>Rare</option>
                                <option <%= card.rarity === 'Holo Rare' ? 'selected' : '' %>>Holo Rare</option>
                                <option <%= card.rarity === 'Ultra Rare' ? 'selected' : '' %>>Ultra Rare</option>
                                <option <%= card.rarity === 'Secret Rare' ? 'selected' : '' %>>Secret Rare</option>
                            </select>
                        </div>
                    </div>

                    <!-- Price & Quantity -->
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Purchase Price (S$)</label>
                            <input type="number" step="0.01" class="form-control"
                                name="purchase_price"
                                value="<%= card.purchase_price %>"
                                min="0" required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Estimated Value (S$)</label>
                            <input type="number" step="0.01" class="form-control"
                                name="estimated_value"
                                value="<%= card.estimated_value %>"
                                min="0" required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Quantity</label>
                            <input type="number" class="form-control"
                                name="quantity"
                                value="<%= card.quantity %>"
                                min="1" required>
                        </div>
                    </div>

                    <!-- Remarks -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Remarks</label>
                        <textarea class="form-control" name="remarks" rows="3"><%= card.remarks || '' %></textarea>
                    </div>

                    <!-- Image -->
                    <div class="mb-2">
                        <label class="form-label fw-semibold">Card Image Artwork</label>
                        <input type="file" class="form-control" name="image" accept="image/*">
                    </div>

                    <p class="text-muted small mb-4">
                        Leave this empty to keep the current image.
                    </p>

                    <!-- Buttons -->
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a href="/card/<%= card.card_id %>" class="btn btn-secondary px-4 me-md-2">
                            Cancel
                        </a>

                        <button type="submit" class="btn btn-primary px-5 fw-semibold">
                            Save Changes
                        </button>
                    </div>

                </form>

            </div>

        </div>
    </div>
</div>

<script>
    function confirmSave() {
        return confirm("Are you sure you want to save these changes?");
    }
</script>

</body>
</html>