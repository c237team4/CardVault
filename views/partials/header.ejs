<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title><%= typeof title !== 'undefined' ? title : 'CardVault' %></title>

  <style>
    .logout-btn {
      border: 1px solid rgba(203, 166, 95, 0.55);
      color: #cba65f;
      background: transparent;
      transition: all 0.3s ease;
    }

    .logout-btn:hover {
      background-color: #cba65f;
      color: #212529;
      border-color: #cba65f;
      transform: translateY(-2px);
      box-shadow: 0 4px 10px rgba(203, 166, 95, 0.35);
    }
  </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow">
  <div class="container">

    <a class="navbar-brand" href="<%= (typeof user !== 'undefined' && user)
      ? (user.role === 'admin' ? '/admin-dashboard' : '/dashboard')
      : '/' %>">
      CardVault
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto">
      </ul>

      <ul class="navbar-nav">
        <% if (typeof user !== 'undefined' && user) { %>
          <li class="nav-item">
            <a class="btn btn-sm logout-btn" href="/logout">
              Logout
            </a>
          </li>
        <% } %>
      </ul>
    </div>

  </div>
</nav>

<div class="container py-4">