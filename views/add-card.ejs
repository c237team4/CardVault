<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CardVault - Add New Card</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #0a0c12;
            background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%);
            font-family: Archivo, system-ui, sans-serif;
        }
        .form-card {
            background: #12151e;
            border: 1px solid rgba(203, 166, 95, .25);
            border-radius: 12px;
            box-shadow: 0 24px 60px rgba(0, 0, 0, .55);
            padding: 2.5rem;
        }

        /* ==== CardVault dark vault theme ==== */
        h2 { font-family: 'Instrument Serif', serif; font-weight: 400 !important; color: #f2ede1; }
        .text-muted { color: #8a90a4 !important; }
        .form-card hr { border-color: rgba(203,166,95,.35); opacity: 1; }
        .form-label { color: #d8dce8; }
        .form-control, .form-select { background-color: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.14); color: #f2ede1; }
        .form-control:focus, .form-select:focus { background-color: rgba(255,255,255,.04); border-color: rgba(203,166,95,.7); color: #f2ede1; box-shadow: 0 0 0 .25rem rgba(203,166,95,.15); }
        .form-control::placeholder { color: #5a6175; }
        .form-select option { background: #12151e; color: #f2ede1; }
        .form-control[type=file]::file-selector-button { background: rgba(214,179,106,.15); border: none; color: #cba65f; }
        .btn-success { background: linear-gradient(180deg, #e0bf7c, #c9a35c); border: none; color: #1c1508; font-weight: 600; }
        .btn-success:hover { background: linear-gradient(180deg, #e8c988, #d3ad64); color: #1c1508; }
        .btn-secondary { background: transparent; border: 1px solid rgba(255,255,255,.24); color: #e8e4d8; }
        .btn-secondary:hover { background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.5); color: #fff; }
    </style>
</head>

<body>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-7">
            
            <div class="form-card">
                <h2 class="fw-bold text-center mb-2">Add New Card</h2>
                <p class="text-muted text-center mb-4">Select the details to add a new piece to your vault collection.</p>
                <hr class="mb-4">

                <form action="/add-card" method="POST" enctype="multipart/form-data">

                    <!-- Row 1: Card Name -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Card Name</label>
                        <input type="text" class="form-control" name="card_name" placeholder="e.g., Gengar Mysterious Mountains" required>
                    </div>

                    <!-- Row 2: Genre & Condition Dropdowns -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Genre</label>
                            <select class="form-select" name="genre_id" required>
                                <option value="" disabled selected>Select Genre</option>
                                <option value="1">Trading Card Games</option>
                                <option value="2">Sport Cards</option>
                                <option value="3">Others</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Condition</label>
                            <select class="form-select" name="condition_id" required>
                                <option value="" disabled selected>Select Condition</option>
                                <option value="1">Mint</option>
                                <option value="2">Near Mint</option>
                                <option value="3">Excellent</option>
                                <option value="4">Good</option>
                                <option value="5">Played</option>
                                <option value="6">Poor</option>
                            </select>
                        </div>
                    </div>

                    <!-- Row 3: Category & Rarity Dropdowns -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Category</label>
                            <select class="form-select" name="category" required>
                                <option value="" disabled selected>Select Category</option>
                                <option>digimon</option>
                                <option>football</option>
                                <option>formula 1</option>
                                <option>NBA</option>
                                <option>One Piece</option>
                                <option>Pokemon</option>
                                <option>Yu-Gi-Oh!</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Rarity</label>
                            <select class="form-select" name="rarity" required>
                                <option value="" disabled selected>Select Rarity</option>
                                <option>Common</option>
                                <option>Uncommon</option>
                                <option>Rare</option>
                                <option>Holo Rare</option>
                                <option>Ultra Rare</option>
                                <option>Secret Rare</option>
                            </select>
                        </div>
                    </div>

                    <!-- Row 4: Financials & Duplicates (Fixed and Fully Populated) -->
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Purchase Price (S$)</label>
                            <input type="number" step="0.01" class="form-control" name="purchase_price" value="0.00" min="0" required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Estimated Value (S$)</label>
                            <input type="number" step="0.01" class="form-control" name="estimated_value" value="0.00" min="0" required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Quantity</label>
                            <input type="number" class="form-control" name="quantity" value="1" min="1" required>
                        </div>
                    </div>

                    <!-- Row 5: Remarks -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Remarks</label>
                        <textarea class="form-control" name="remarks" rows="3" placeholder="Add unique details here..."></textarea>
                    </div>

                    <!-- Row 6: Image Upload -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Card Image Artwork</label>
                        <input type="file" class="form-control" name="image" accept="image/*">
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a href="/dashboard" class="btn btn-secondary px-4 me-md-2">Cancel</a>
                        <button type="submit" class="btn btn-success px-5 fw-semibold">+ Add New Card</button>
                    </div>

                </form>
            </div>

        </div>
    </div>
</div>

</body>
</html>