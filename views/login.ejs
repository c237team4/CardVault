<%- include('partials/header', { title: 'Login - CardVault' }) %>

<!-- ============================================================
     LOGIN  |  Owner: Tan Boon Meng (25052694)
     Renders with: messages (flash success), errors (flash error)
     Posts to: POST /login
     ============================================================ -->

<div class="row justify-content-center">
  <div class="col-md-5">

    <h2 class="mb-3">Log in to CardVault</h2>

    <%# 'messages' carries success (e.g. just registered), 'errors' carries
        failures (e.g. wrong password). Two separate flash keys so they can be
        styled differently. %>
    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% messages.forEach(msg => { %>
          <div><%= msg %></div>
        <% }) %>
      </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(msg => { %>
          <div><%= msg %></div>
        <% }) %>
      </div>
    <% } %>

    <form action="/login" method="POST">

      <div class="mb-3">
        <label class="form-label" for="email">Email</label>
        <input class="form-control" type="email" id="email" name="email" required>
      </div>

      <div class="mb-3">
        <label class="form-label" for="password">Password</label>
        <input class="form-control" type="password" id="password" name="password" required>
      </div>

      <button class="btn btn-primary w-100" type="submit">Log in</button>
    </form>

    <p class="mt-3 mb-0">No account yet? <a href="/register">Register</a></p>

  </div>
</div>

<%- include('partials/footer') %>
