<%- include('partials/header', { title: 'All Cards - CardVault' }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ==== CardVault dark vault theme — styling overrides only ==== */
body { background: #0a0c12; font-family: Archivo, system-ui, sans-serif; }
.bg-light { background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%) !important; }
h1, .display-4 { font-family: 'Instrument Serif', serif; font-weight: 400 !important; color: #f2ede1; }
.text-muted { color: #8a90a4 !important; }
.card { background: #12151e; border: 1px solid rgba(203,166,95,.25) !important; }
.shadow { box-shadow: 0 20px 50px rgba(0,0,0,.45) !important; }
.card-body { color: #d8dce8; }
.card-title { color: #f2ede1; }
.card-body strong { color: #cba65f; }
.card .bg-light { background: #171c28 !important; color: #6d7488; font: 400 12px ui-monospace, Menlo, monospace; letter-spacing: .1em; }
.form-control, .form-select { background-color: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.14); color: #f2ede1; }
.form-control:focus, .form-select:focus { background-color: rgba(255,255,255,.04); border-color: rgba(203,166,95,.7); color: #f2ede1; box-shadow: 0 0 0 .25rem rgba(203,166,95,.15); }
.form-control::placeholder { color: #5a6175; }
.form-select option { background: #12151e; color: #f2ede1; }
.btn-primary { background: linear-gradient(180deg, #e0bf7c, #c9a35c); border: none; color: #1c1508; font-weight: 600; }
.btn-primary:hover { background: linear-gradient(180deg, #e8c988, #d3ad64); color: #1c1508; }
.btn-secondary { background: transparent; border: 1px solid rgba(255,255,255,.24); color: #e8e4d8; }
.btn-secondary:hover { background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.5); color: #fff; }
.btn-dark { background: transparent; border: 1px solid rgba(203,166,95,.5); color: #cba65f; }
.btn-dark:hover { background: rgba(214,179,106,.15); border-color: #cba65f; color: #e0bf7c; }
.badge.bg-primary { background: rgba(100,140,225,.18) !important; color: #a3bcf2; }
.badge.bg-danger { background: rgba(214,179,106,.18) !important; color: #e0c993; }
.badge.bg-success { background: rgba(110,200,140,.16) !important; color: #a2d9b4; }
.badge.bg-info { background: rgba(120,195,220,.16) !important; color: #a8d9e8; }
/* ==== end overrides ==== */
</style>




<div class="bg-light min-vh-100 py-5">

    <div class="container">


        <!-- Page Header -->

        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>

                <h1 class="fw-bold">
                    All Cards
                </h1>

                <p class="text-muted">
                    View all cards collected by users.
                </p>

            </div>


            <a href="/admin-dashboard" class="btn btn-secondary">

                Back to Dashboard

            </a>

        </div>


        <!-- Search and Filter -->

        <div class="card shadow border-0 mb-4">

            <div class="card-body">


                <form method="GET" action="/admin/all-cards">


                    <div class="row g-3">


                        <!-- Search -->

                        <div class="col-md-5">

                            <input type="text"
                                   name="search"
                                   class="form-control"
                                   placeholder="Search card name..."
                                   value="<%= search %>">

                        </div>


                        <!-- Category -->

                        <div class="col-md-3">

                            <select name="category" class="form-select">


                                <option value="">

                                    All Categories

                                </option>



                                <% categories.forEach(category => { %>


                                    <option value="<%= category.category %>"
                                        <%= searchCategory === category.category ? 'selected' : '' %>>


                                        <%= category.category %>


                                    </option>


                                <% }) %>


                            </select>


                        </div>


                        <!-- Rarity -->

                        <div class="col-md-3">

                            <select name="rarity" class="form-select">


                                <option value="">

                                    All Rarities

                                </option>



                                <% rarities.forEach(rarity => { %>


                                    <option value="<%= rarity.rarity %>"
                                        <%= searchRarity === rarity.rarity ? 'selected' : '' %>>


                                        <%= rarity.rarity %>


                                    </option>


                                <% }) %>


                            </select>


                        </div>


                        <!-- Search Button -->

                        <div class="col-md-1">


                            <button class="btn btn-primary w-100">

                                Search

                            </button>


                        </div>


                    </div>


                </form>


            </div>


        </div>



        <!-- Card Grid -->


        <div class="row g-4">



            <% if(cards.length > 0){ %>



                <% cards.forEach(card => { %>



                    <div class="col-md-4 col-lg-3">



                        <div class="card shadow border-0 h-100 rounded-4 overflow-hidden">



                            <!-- Card Image -->


                            <% if(card.image){ %>


                                <img src="/images/<%= card.image %>"
                                     class="card-img-top"
                                     style="height:220px; object-fit:contain;">



                            <% } else { %>



                                <div class="d-flex justify-content-center align-items-center bg-light"
                                     style="height:220px;">


                                    No Image


                                </div>



                            <% } %>





                            <!-- Card Details -->


                            <div class="card-body d-flex flex-column">


                                <h5 class="card-title fw-bold">

                                    <%= card.card_name %>

                                </h5>





                                <!-- Owner -->


                                <p class="mb-3">

                                    <strong>Owner:</strong>

                                    <%= card.username %>

                                </p>





                                <!-- Category -->


                                <div class="mb-2">


                                    <span class="badge bg-primary">

                                        Category

                                    </span>


                                    <span class="badge bg-primary ms-1">

                                        <%= card.category %>

                                    </span>


                                </div>





                                <!-- Rarity -->


                                <div class="mb-2">


                                    <span class="badge bg-danger">

                                        Rarity

                                    </span>


                                    <span class="badge bg-danger ms-1">

                                        <%= card.rarity %>

                                    </span>


                                </div>





                                <!-- Condition -->


                                <div class="mb-2">


                                    <span class="badge bg-success">

                                        Condition

                                    </span>


                                    <span class="badge bg-success ms-1">

                                        <%= card.condition_name %>

                                    </span>


                                </div>





                                <!-- Value -->


                                <div class="mb-3">


                                    <span class="badge bg-info">

                                        Value

                                    </span>


                                    <span class="badge bg-info ms-1">

                                        $<%= card.estimated_value %>

                                    </span>


                                </div>





                                <!-- View Details Button -->


                                <div class="mt-auto d-grid">


                                    <a href="/admin/card/<%= card.card_id %>"
                                       class="btn btn-dark rounded-pill">

                                        View Details

                                    </a>


                                </div>



                            </div>



                        </div>



                    </div>



                <% }) %>



            <% } else { %>




                <div class="text-center py-5">


                    <h5 class="text-muted">

                        No cards found.

                    </h5>


                </div>



            <% } %>




        </div>



    </div>


</div>


<%- include('partials/footer') %>