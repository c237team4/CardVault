<%- include('partials/header', { title: 'User Collection - CardVault' }) %>

<div class="bg-light min-vh-100 py-5">

    <div class="container">

        <!-- Page Header -->
        <div class="card shadow border-0 mb-4">

            <div class="card-header bg-primary text-white">

                <h2 class="mb-0">
                    <%= selectedUser.username %>'s Collection
                </h2>

            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6">

                        <h5>
                            <span class="badge bg-primary">Username</span>
                        </h5>

                        <p class="fs-5">
                            <%= selectedUser.username %>
                        </p>

                    </div>

                    <div class="col-md-6">

                        <h5>
                            <span class="badge bg-success">Email</span>
                        </h5>

                        <p class="fs-5">
                            <%= selectedUser.email %>
                        </p>

                    </div>

                </div>

                <a href="/admin-dashboard" class="btn btn-secondary mt-2">
                    ← Back to Admin Dashboard
                </a>

            </div>

        </div>


        <!-- Cards Table -->

        <div class="card shadow border-0">

            <div class="card-header bg-dark text-white">

                <h4 class="mb-0">
                    Card Collection
                </h4>

            </div>

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-primary">

                            <tr>

                                <th>Image</th>
                                <th>Card Name</th>
                                <th>Category</th>
                                <th>Condition</th>
                                <th>Rarity</th>
                                <th>Purchase Price</th>
                                <th>Estimated Value</th>
                                <th>Quantity</th>
                                <th>Remarks</th>
                                <th>Date Added</th>

                            </tr>

                        </thead>

                        <tbody>

                        <% if(cards.length > 0){ %>

                            <% cards.forEach(card => { %>

                            <tr>

                                <td>

                                    <% if(card.image){ %>

                                        <img src="/images/<%= card.image %>"
                                             width="90"
                                             height="90"
                                             class="rounded shadow-sm"
                                             style="object-fit:cover;">

                                    <% } else { %>

                                        <span class="badge bg-secondary">
                                            No Image
                                        </span>

                                    <% } %>

                                </td>

                                <td>
                                    <strong><%= card.card_name %></strong>
                                </td>

                                <td>
                                    <span class="badge bg-info text-dark">
                                        <%= card.category %>
                                    </span>
                                </td>

                                <td>
                                    <span class="badge bg-warning text-dark">
                                        <%= card.condition_name %>
                                    </span>
                                </td>

                                <td>
                                    <span class="badge bg-danger">
                                        <%= card.rarity %>
                                    </span>
                                </td>

                                <td class="text-success fw-bold">
                                    $<%= Number(card.purchase_price).toFixed(2) %>
                                </td>

                                <td class="text-primary fw-bold">
                                    $<%= Number(card.estimated_value).toFixed(2) %>
                                </td>

                                <td>

                                    <span class="badge bg-success">

                                        <%= card.quantity %>

                                    </span>

                                </td>

                                <td>
                                    <%= card.remarks || "-" %>
                                </td>

                                <td>
                                    <%= card.date_added %>
                                </td>

                            </tr>

                            <% }) %>

                        <% } else { %>

                            <tr>

                                <td colspan="10" class="text-center py-5">

                                    <div class="alert alert-warning mb-0">

                                        <h5>No Cards Found</h5>

                                        This user has not added any cards yet.

                                    </div>

                                </td>

                            </tr>

                        <% } %>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include('partials/footer') %>