<%- include('partials/header', { title: 'User Collection - CardVault' }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ==== CardVault dark vault theme — styling overrides only ==== */
body { background: #0a0c12; font-family: Archivo, system-ui, sans-serif; }
.bg-light { background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%) !important; }
h2, h4, h5 { font-family: 'Instrument Serif', serif; font-weight: 400 !important; }
.text-muted { color: #8a90a4 !important; }
.card { background: #12151e; border: 1px solid rgba(203,166,95,.25) !important; }
.shadow, .shadow-sm { box-shadow: 0 20px 50px rgba(0,0,0,.45) !important; }
.card-header.bg-primary { background: #0d1017 !important; border-bottom: 1px solid rgba(203,166,95,.25); }
.card-header.bg-dark { background: #0d1017 !important; border-bottom: 1px solid rgba(203,166,95,.25); }
.card-header h2, .card-header h4 { color: #f2ede1; }
.card-body { color: #d8dce8; }
.card-body h4 { color: #f2ede1; }
.card-body b { color: #cba65f; }
.card-body .card-img-top { background: #171c28; }
.card-body hr { border-color: rgba(203,166,95,.3); opacity: 1; }
.text-success { color: #cba65f !important; }
.text-primary { color: #a3bcf2 !important; }
.btn-secondary { background: transparent; border: 1px solid rgba(203,166,95,.5); color: #cba65f; }
.btn-secondary:hover { background: rgba(214,179,106,.15); border-color: #cba65f; color: #e0bf7c; }
.btn-danger { background: transparent; border: 1px solid rgba(224,120,120,.5); color: #e8a0a0; }
.btn-danger:hover { background: rgba(224,120,120,.12); border-color: #e8a0a0; color: #f2b8b8; }
.badge.bg-primary { background: rgba(100,140,225,.18) !important; color: #a3bcf2; }
.badge.bg-info { background: rgba(120,195,220,.16) !important; }
.badge.bg-info.text-dark { color: #a8d9e8 !important; }
.badge.bg-warning { background: rgba(214,179,106,.2) !important; }
.badge.bg-warning.text-dark { color: #e0c993 !important; }
.badge.bg-danger { background: rgba(214,179,106,.18) !important; color: #e0c993; }
.badge.bg-success { background: rgba(110,200,140,.16) !important; color: #a2d9b4; }
.bg-secondary { background: #171c28 !important; color: #6d7488 !important; }
.alert-warning { background: rgba(214,179,106,.08); border: 1px solid rgba(203,166,95,.35); color: #e0c993; }
/* ==== end overrides ==== */
</style>

<div class="bg-light min-vh-100 py-5">

<div class="container">

    <!-- User Information -->
    <div class="card shadow border-0 mb-4">

        <div class="card-header bg-primary text-white">
            <h2 class="mb-0"><%= selectedUser.username %>'s Collection</h2>
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6">
                    <span class="badge bg-primary">Username</span>
                    <p class="fs-5"><%= selectedUser.username %></p>
                </div>

                <div class="col-md-6">
                    <span class="badge bg-success">Email</span>
                    <p class="fs-5"><%= selectedUser.email %></p>
                </div>

            </div>

            <a href="/admin-dashboard" class="btn btn-secondary">
                ← Back to Admin Dashboard
            </a>

        </div>

    </div>


    <!-- Card Collection -->

    <div class="card shadow border-0">

        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Card Collection</h4>
        </div>


        <div class="card-body">

        <% if(cards.length > 0){ %>

            <div class="row g-4">

            <% cards.forEach(card => { %>

                <div class="col-lg-4 col-md-6">

                    <div class="card h-100 shadow-sm">


                        <% if(card.image){ %>

                            <img src="/images/<%= card.image %>"
                                 class="card-img-top p-3"
                                 style="height:250px;object-fit:contain;">

                        <% } else { %>

                            <div class="bg-secondary text-white d-flex justify-content-center align-items-center"
                                 style="height:250px;">
                                No Image
                            </div>

                        <% } %>



                        <div class="card-body">

                            <h4 class="text-center fw-bold">
                                <%= card.card_name %>
                            </h4>

                            <hr>

                            <p>
                                <b>Category:</b>
                                <span class="badge bg-info text-dark">
                                    <%= card.category %>
                                </span>
                            </p>

                            <p>
                                <b>Condition:</b>
                                <span class="badge bg-warning text-dark">
                                    <%= card.condition_name %>
                                </span>
                            </p>

                            <p>
                                <b>Rarity:</b>
                                <span class="badge bg-danger">
                                    <%= card.rarity %>
                                </span>
                            </p>

                            <p>
                                <b>Quantity:</b>
                                <span class="badge bg-success">
                                    <%= card.quantity %>
                                </span>
                            </p>

                            <p>
                                <b>Purchase:</b>
                                <span class="text-success fw-bold">
                                    $<%= Number(card.purchase_price).toFixed(2) %>
                                </span>
                            </p>

                            <p>
                                <b>Value:</b>
                                <span class="text-primary fw-bold">
                                    $<%= Number(card.estimated_value).toFixed(2) %>
                                </span>
                            </p>

                            <p>
                                <b>Remarks:</b>
                                <br>
                                <%= card.remarks || "-" %>
                            </p>

                            <small class="text-muted">
                                Added: <%= card.date_added %>
                            </small>

                            <form action="/admin/delete-card/<%= card.card_id %>"
                                  method="POST"
                                  onsubmit="return confirm('Delete this card?');">

                                 <input
                                     type="hidden"
                                     name="userId"
                                     value="<%= selectedUser.user_id %>">
                                
                                <button class="btn btn-danger btn-sm float-end">
                                    Delete
                                </button>
                                
                            </form>

                        </div>

                    </div>

                </div>

            <% }) %>

            </div>


        <% } else { %>

            <div class="alert alert-warning text-center">
                <h5>No Cards Found</h5>
                This user has not added any cards yet.
            </div>

        <% } %>


        </div>

    </div>


</div>

</div>

<%- include('partials/footer') %>