<%- include('partials/header', { title: 'User Collection - CardVault' }) %>

<div class="bg-light min-vh-100 py-5">

<div class="container">

    <!-- User Information -->
    <div class="card shadow border-0 mb-4">

        <div class="card-header bg-primary text-white">
            <h2 class="mb-0"><%= selectedUser.username %>'s Collection</h2>
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6">
                    <span class="badge bg-primary">Username</span>
                    <p class="fs-5"><%= selectedUser.username %></p>
                </div>

                <div class="col-md-6">
                    <span class="badge bg-success">Email</span>
                    <p class="fs-5"><%= selectedUser.email %></p>
                </div>

            </div>

            <a href="/admin-dashboard" class="btn btn-secondary">
                ← Back to Admin Dashboard
            </a>

        </div>

    </div>


    <!-- Card Collection -->

    <div class="card shadow border-0">

        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Card Collection</h4>
        </div>


        <div class="card-body">

        <% if(cards.length > 0){ %>

            <div class="row g-4">

            <% cards.forEach(card => { %>

                <div class="col-lg-4 col-md-6">

                    <div class="card h-100 shadow-sm">


                        <% if(card.image){ %>

                            <img src="/images/<%= card.image %>"
                                 class="card-img-top p-3"
                                 style="height:250px;object-fit:contain;">

                        <% } else { %>

                            <div class="bg-secondary text-white d-flex justify-content-center align-items-center"
                                 style="height:250px;">
                                No Image
                            </div>

                        <% } %>



                        <div class="card-body">

                            <h4 class="text-center fw-bold">
                                <%= card.card_name %>
                            </h4>

                            <hr>

                            <p>
                                <b>Category:</b>
                                <span class="badge bg-info text-dark">
                                    <%= card.category %>
                                </span>
                            </p>

                            <p>
                                <b>Condition:</b>
                                <span class="badge bg-warning text-dark">
                                    <%= card.condition_name %>
                                </span>
                            </p>

                            <p>
                                <b>Rarity:</b>
                                <span class="badge bg-danger">
                                    <%= card.rarity %>
                                </span>
                            </p>

                            <p>
                                <b>Quantity:</b>
                                <span class="badge bg-success">
                                    <%= card.quantity %>
                                </span>
                            </p>

                            <p>
                                <b>Purchase:</b>
                                <span class="text-success fw-bold">
                                    $<%= Number(card.purchase_price).toFixed(2) %>
                                </span>
                            </p>

                            <p>
                                <b>Value:</b>
                                <span class="text-primary fw-bold">
                                    $<%= Number(card.estimated_value).toFixed(2) %>
                                </span>
                            </p>

                            <p>
                                <b>Remarks:</b>
                                <br>
                                <%= card.remarks || "-" %>
                            </p>

                            <small class="text-muted">
                                Added: <%= card.date_added %>
                            </small>

                        </div>

                    </div>

                </div>

            <% }) %>

            </div>


        <% } else { %>

            <div class="alert alert-warning text-center">
                <h5>No Cards Found</h5>
                This user has not added any cards yet.
            </div>

        <% } %>


        </div>

    </div>


</div>

</div>

<%- include('partials/footer') %>