<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CardVault - Remove from Wishlist</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #0a0c12;
            background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%);
            font-family: Archivo, system-ui, sans-serif;
            min-height: 100vh;
        }
        .form-card {
            background: #12151e;
            border: 1px solid rgba(203, 166, 95, .25);
            border-radius: 12px;
            box-shadow: 0 24px 60px rgba(0, 0, 0, .55);
            padding: 2.5rem;
        }

        /* ==== CardVault dark vault theme ==== */
        h2 { font-family: 'Instrument Serif', serif; font-weight: 400 !important; color: #f2ede1; }
        .text-muted { color: #8a90a4 !important; }
        .form-card hr { border-color: rgba(203,166,95,.35); opacity: 1; }
        .form-label { color: #d8dce8; }
        .form-control, .form-select { background-color: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.14); color: #f2ede1; }
        .form-control:focus, .form-select:focus { background-color: rgba(255,255,255,.04); border-color: rgba(203,166,95,.7); color: #f2ede1; box-shadow: 0 0 0 .25rem rgba(203,166,95,.15); }
        .form-control::placeholder { color: #5a6175; }
        .form-select option { background: #12151e; color: #f2ede1; }
        .form-control[type=file]::file-selector-button { background: rgba(214,179,106,.15); border: none; color: #cba65f; }
        .btn-success { background: linear-gradient(180deg, #e0bf7c, #c9a35c); border: none; color: #1c1508; font-weight: 600; }
        .btn-success:hover { background: linear-gradient(180deg, #e8c988, #d3ad64); color: #1c1508; }
        .btn-secondary { background: transparent; border: 1px solid rgba(255,255,255,.24); color: #e8e4d8; }
        .btn-secondary:hover { background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.5); color: #fff; }

        /* -- added for the remove-wishlist confirmation page -- */
        .btn-danger { background: linear-gradient(180deg, #d97b7b, #c25c5c); border: none; color: #1c1508; font-weight: 600; }
        .btn-danger:hover { background: linear-gradient(180deg, #e08a8a, #cc6868); color: #1c1508; }
        .list-group-item { background: #171c28 !important; border-color: rgba(255,255,255,.08) !important; color: #d8dce8; }
        .list-group-item strong { color: #f2ede1; }
        p { color: #d8dce8; }
    </style>
</head>



<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">CardVault</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/dashboard">Inventory</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/wishlist">Wishlist</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-5">
    <h2 class="text-center mb-4">Remove from Wishlist</h2>

    <div class="form-card mx-auto" style="max-width: 500px;">
        <p>Are you sure you want to remove this card from your wishlist?</p>
        <ul class="list-group list-group-flush mb-3">
          <li class="list-group-item"><strong>Card Name:</strong> <%= item.card_name %></li>
          <li class="list-group-item"><strong>Category:</strong> <%= item.category %></li>
          <li class="list-group-item">
            <strong>Target Price:</strong>
            <% if (item.target_price !== null) { %>
              $<%= Number(item.target_price).toFixed(2) %>
            <% } else { %>
              <span class="text-muted">-</span>
            <% } %>
          </li>
          <li class="list-group-item"><strong>Notes:</strong> <%= item.notes || '-' %></li>
        </ul>

        <form action="/remove-wishlist/<%= item.wishlist_id %>" method="POST" class="d-flex justify-content-between">
          <a href="/wishlist" class="btn btn-secondary">Cancel</a>
          <button type="submit" class="btn btn-danger">Yes, Remove It</button>
        </form>
    </div>
  </div>
</body>
</html>
