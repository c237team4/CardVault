<%- include('partials/header', { title: 'Meetups - CardVault' }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  /* ===== CardVault vault theme — Meetups (styling only) ===== */
  body {
    background: #0a0c12;
    color: #d8dae0;
  }

  .container.my-5 h1.fw-bold {
    font-family: 'Instrument Serif', Georgia, serif;
    font-weight: 400 !important;
    font-size: 3.25rem;
    letter-spacing: 0.5px;
    color: #f4f2ee;
  }
  .container.my-5 .text-muted {
    color: #8b8f9a !important;
  }

  /* Featured "next meetup" card */
  .container.my-5 .card {
    background: linear-gradient(160deg, #12151d 0%, #0d1016 100%);
    border: 1px solid rgba(203, 166, 95, 0.28) !important;
    border-radius: 14px;
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.55) !important;
  }
  .container.my-5 .card .card-title,
  .container.my-5 .card h2.fw-bold {
    font-family: 'Instrument Serif', Georgia, serif;
    font-weight: 400 !important;
    color: #f4f2ee;
    letter-spacing: 0.4px;
  }
  .container.my-5 .card h2.fw-bold { font-size: 2.4rem; }
  .container.my-5 .card .card-title { font-size: 1.5rem; }

  .container.my-5 .card p { color: #c3c6cf; }
  .container.my-5 .card p strong { color: #e0bf7c; font-weight: 600; }
  .container.my-5 .card p.text-muted { color: #8b8f9a !important; }

  /* NEXT MEETUP badge */
  .container.my-5 .badge.bg-warning {
    background: rgba(203, 166, 95, 0.16) !important;
    color: #e0bf7c !important;
    border: 1px solid rgba(203, 166, 95, 0.4);
    font-weight: 600;
    letter-spacing: 1.5px;
    padding: 0.5em 0.9em;
    border-radius: 999px;
  }

  /* "Coming up after that" heading */
  .container.my-5 h5.text-muted {
    color: #8b8f9a !important;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.85rem;
  }

  /* Buttons */
  .container.my-5 .btn-success {
    background: linear-gradient(180deg, #e0bf7c 0%, #cba65f 100%);
    border: none;
    color: #0a0c12;
    font-weight: 600;
    letter-spacing: 0.3px;
    border-radius: 8px;
    padding: 0.6em 1.4em;
    box-shadow: 0 6px 18px rgba(203, 166, 95, 0.25);
  }
  .container.my-5 .btn-success:hover {
    background: linear-gradient(180deg, #ecca88 0%, #d9b46e 100%);
    color: #0a0c12;
  }
  .container.my-5 .btn-outline-primary {
    color: #e0bf7c;
    border-color: rgba(203, 166, 95, 0.5);
    background: transparent;
    border-radius: 7px;
  }
  .container.my-5 .btn-outline-primary:hover {
    background: rgba(203, 166, 95, 0.14);
    color: #f4f2ee;
    border-color: #cba65f;
  }
  .container.my-5 .btn-outline-danger {
    color: #d98a86;
    border-color: rgba(200, 90, 84, 0.45);
    background: transparent;
    border-radius: 7px;
  }
  .container.my-5 .btn-outline-danger:hover {
    background: rgba(200, 90, 84, 0.15);
    color: #f0b6b2;
    border-color: #c85a54;
  }

  /* Empty state */
  .container.my-5 .py-5 h4 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-weight: 400;
    color: #f4f2ee;
  }
</style>



<!-- ============================================================
     Tan Boon Meng (25052694)
     Members can view upcoming meetups.
     Admin can Delete event schedules

     Mok Zhan Fung
     Responsible for Add Meetup feature.
     Admin can create new meetup events.
     ============================================================ -->

<div class="container my-5">

  <div class="text-center mb-5">
    <h1 class="fw-bold">Members Meetups</h1>
    <p class="text-muted">Monthly gatherings for collectors to trade and share their cards in person.</p>
  </div>



  <% if (user && user.role === 'admin') { %>
    <div class="text-center mb-4">
      <a href="/admin/add-meetup" class="btn btn-success">+ Add Meetup</a>
    </div>
  <% } %>


  <% if (meetups.length > 0) { %>

    <!-- Featured: nearest upcoming (big card) -->
    <% var next = meetups[0]; %>
    <div class="card shadow border-0 mb-5">
      <div class="card-body p-5">
        <span class="badge bg-warning text-dark mb-3">NEXT MEETUP</span>
        <h2 class="fw-bold mb-3"><%= next.title %></h2>
        <p class="fs-5 mb-1"><strong>Date:</strong> <%= next.date_display %></p>
        <% if (next.start_display) { %>
          <p class="fs-5 mb-1"><strong>Time:</strong> <%= next.start_display %> &ndash; <%= next.end_display %></p>
        <% } %>
        <p class="fs-5 mb-1"><strong>Location:</strong> <%= next.location %></p>
        <% if (next.description) { %>
          <p class="text-muted mt-3 mb-0"><%= next.description %></p>
        <% } %>
        <% if (user && user.role === 'admin') { %>
          <div class="mt-4">


            <a href="/admin/edit-meetup/<%= next.meetup_id %>" class="btn btn-outline-primary btn-sm">Edit</a>


            <form action="/admin/delete-meetup/<%= next.meetup_id %>" method="POST" class="d-inline"
                  onsubmit="return confirm('Delete this meetup?');">
              <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>
    

    <!-- The meetups after the nearest one (small cards) -->
    <% if (meetups.length > 1) { %>
      <h5 class="text-muted mb-3">Coming up after that</h5>
      <div class="row g-4">
        <% for (var i = 1; i < meetups.length; i++) { %>
          <% var m = meetups[i]; %>
          <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
              <div class="card-body">
                <h5 class="card-title fw-bold"><%= m.title %></h5>
                <p class="mb-1"><strong>Date:</strong> <%= m.date_display %></p>
                <% if (m.start_display) { %>
                  <p class="mb-1"><strong>Time:</strong> <%= m.start_display %> &ndash; <%= m.end_display %></p>
                <% } %>
                <p class="mb-1"><strong>Location:</strong> <%= m.location %></p>
                <% if (user && user.role === 'admin') { %>
                  <div class="mt-3">
                    <a href="/admin/edit-meetup/<%= m.meetup_id %>" class="btn btn-outline-primary btn-sm">Edit</a>
                    <form action="/admin/delete-meetup/<%= m.meetup_id %>" method="POST" class="d-inline"
                          onsubmit="return confirm('Delete this meetup?');">
                      <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                    </form>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>

  <% } else { %>
    <div class="text-center py-5">
      <h4>No upcoming meetups scheduled.</h4>
      <p class="text-muted">Check back soon for the next members meetups.</p>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>
