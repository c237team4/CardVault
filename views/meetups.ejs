<%- include('partials/header', { title: 'Meetups - CardVault' }) %>

<!-- ============================================================
     MEETUPS SCHEDULE  |  Owner: Tan Boon Meng (Student A) - Read
     Any logged-in member can view upcoming meetups.
     Layout: nearest upcoming = big featured card,
             the next few = small cards.
     Admin Add / Edit / Delete buttons come in later steps.
     Renders with: user, meetups (already filtered to upcoming, soonest first)
     ============================================================ -->

<div class="container my-5">

  <div class="text-center mb-5">
    <h1 class="fw-bold">Community Meetups</h1>
    <p class="text-muted">Monthly gatherings for collectors to trade and share their cards in person.</p>
  </div>



  <% if (user && user.role === 'admin') { %>
    <div class="text-center mb-4">
      <a href="/admin/add-meetup" class="btn btn-success">+ Add Meetup</a>
    </div>
  <% } %>


  <% if (meetups.length > 0) { %>

    <!-- Featured: nearest upcoming (big card) -->
    <% var next = meetups[0]; %>
    <div class="card shadow border-0 mb-5">
      <div class="card-body p-5">
        <span class="badge bg-warning text-dark mb-3">NEXT MEETUP</span>
        <h2 class="fw-bold mb-3"><%= next.title %></h2>
        <p class="fs-5 mb-1"><strong>Date:</strong> <%= next.date_display %></p>
        <% if (next.start_display) { %>
          <p class="fs-5 mb-1"><strong>Time:</strong> <%= next.start_display %> &ndash; <%= next.end_display %></p>
        <% } %>
        <p class="fs-5 mb-1"><strong>Location:</strong> <%= next.location %></p>
        <% if (next.description) { %>
          <p class="text-muted mt-3 mb-0"><%= next.description %></p>
        <% } %>
        <% if (user && user.role === 'admin') { %>
          <div class="mt-4">
            <a href="/admin/edit-meetup/<%= next.meetup_id %>" class="btn btn-outline-primary btn-sm">Edit</a>
            <form action="/admin/delete-meetup/<%= next.meetup_id %>" method="POST" class="d-inline"
                  onsubmit="return confirm('Delete this meetup?');">
              <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>

    <!-- The meetups after the nearest one (small cards) -->
    <% if (meetups.length > 1) { %>
      <h5 class="text-muted mb-3">Coming up after that</h5>
      <div class="row g-4">
        <% for (var i = 1; i < meetups.length; i++) { %>
          <% var m = meetups[i]; %>
          <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
              <div class="card-body">
                <h5 class="card-title fw-bold"><%= m.title %></h5>
                <p class="mb-1"><strong>Date:</strong> <%= m.date_display %></p>
                <% if (m.start_display) { %>
                  <p class="mb-1"><strong>Time:</strong> <%= m.start_display %> &ndash; <%= m.end_display %></p>
                <% } %>
                <p class="mb-1"><strong>Location:</strong> <%= m.location %></p>
                <% if (user && user.role === 'admin') { %>
                  <div class="mt-3">
                    <a href="/admin/edit-meetup/<%= m.meetup_id %>" class="btn btn-outline-primary btn-sm">Edit</a>
                    <form action="/admin/delete-meetup/<%= m.meetup_id %>" method="POST" class="d-inline"
                          onsubmit="return confirm('Delete this meetup?');">
                      <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                    </form>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>

  <% } else { %>
    <div class="text-center py-5">
      <h4>No upcoming meetups scheduled.</h4>
      <p class="text-muted">Check back soon for the next community meetup.</p>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>
