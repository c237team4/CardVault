<%- include('partials/header', { title: 'Edit Role - CardVault' }) %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ==== CardVault dark vault theme — styling overrides only ==== */
body { background: #0a0c12; font-family: Archivo, system-ui, sans-serif; }
.bg-light { background: radial-gradient(120% 100% at 50% 0%, #181d2e 0%, #0e1119 55%, #0a0c12 100%) !important; }
h1, .display-4 { font-family: 'Instrument Serif', serif; font-weight: 400 !important; color: #f2ede1; }
.text-muted { color: #8a90a4 !important; }
.card { background: #12151e; border: 1px solid rgba(203,166,95,.25) !important; }
.shadow { box-shadow: 0 20px 50px rgba(0,0,0,.45) !important; }
.card-header.bg-dark { background: #0d1017 !important; border-bottom: 1px solid rgba(203,166,95,.25); }
.card-header h4 { font-family: 'Instrument Serif', serif; font-weight: 400; color: #f2ede1; letter-spacing: .02em; }
.card-body { color: #d8dce8; }
.card-body h5 { color: #f2ede1; }
.card-body h5 strong { color: #cba65f; }
.form-label { color: #8a90a4; font: 600 12px Archivo, sans-serif; letter-spacing: .18em; text-transform: uppercase; }
.form-select { background-color: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.14); color: #f2ede1; }
.form-select:focus { background-color: rgba(255,255,255,.04); border-color: rgba(203,166,95,.7); color: #f2ede1; box-shadow: 0 0 0 .25rem rgba(203,166,95,.15); }
.form-select option { background: #12151e; color: #f2ede1; }
.btn-warning { background: linear-gradient(180deg, #e0bf7c, #c9a35c); border: none; font-weight: 600; }
.btn-warning, .btn-warning:hover { color: #1c1508 !important; }
.btn-warning:hover { background: linear-gradient(180deg, #e8c988, #d3ad64); }
.btn-secondary { background: transparent; border: 1px solid rgba(255,255,255,.24); color: #e8e4d8; }
.btn-secondary:hover { background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.5); color: #fff; }
/* ==== end overrides ==== */
</style>

<div class="bg-light min-vh-100 py-5">

    <div class="container">

      <div class="row">
        <div class="col-lg-6 mx-auto">

        <div class="card shadow border-0">

            <div class="card-header bg-dark text-white">

                <h4 class="mb-0">
                    Edit User Role
                </h4>

            </div>


            <div class="card-body">

                <h5>
                    Username:
                    <strong><%= selectedUser.username %></strong>
                </h5>

                <p>
                    Email:
                    <%= selectedUser.email %>
                </p>


                <form action="/admin/edit-role/<%= selectedUser.user_id %>" method="POST">


                    <div class="mb-3">

                        <label class="form-label">
                            Select Role
                        </label>


                        <select name="role" class="form-select">

                            <option value="user"
                                <%= selectedUser.role === 'user' ? 'selected' : '' %>>
                                User
                            </option>


                            <option value="admin"
                                <%= selectedUser.role === 'admin' ? 'selected' : '' %>>
                                Admin
                            </option>

                        </select>

                    </div>


                    <button type="submit" class="btn btn-warning text-white">

                        Update Role

                    </button>


                    <a href="/admin-dashboard" class="btn btn-secondary">

                        Cancel

                    </a>


                </form>


            </div>

        </div>

        </div>
      </div>

    </div>

</div>


<%- include('partials/footer') %>