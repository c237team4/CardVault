<%- include('partials/header', { title: 'Add Meetup - CardVault' }) %>

<!-- ============================================================
     ADD MEETUP  |  Owner: Zhan Fung (Student F) - Create
     Admin posts a new community meetup.
     Posts to: POST /admin/add-meetup
     ============================================================ -->

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
          <h4 class="mb-0">Add Meetup Schedule</h4>
        </div>
        <div class="card-body">

          <% if (messages && messages.length > 0) { %>
            <div class="alert alert-danger">
              <% messages.forEach(function(msg){ %>
                <div><%= msg %></div>
              <% }); %>
            </div>
          <% } %>

          <form action="/admin/add-meetup" method="POST">

            <div class="mb-3">
              <label class="form-label fw-semibold">Title</label>
              <input type="text" class="form-control" name="title"
                     placeholder="e.g. Orchard Card Meetup" required>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Location</label>
              <input type="text" class="form-control" name="location"
                     placeholder="e.g. The Heeren (B1-01, 260 Orchard Rd)" required>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Date</label>
              <input type="date" class="form-control" name="meetup_date" required>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Start Time</label>
                <input type="time" class="form-control" name="start_time">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">End Time</label>
                <input type="time" class="form-control" name="end_time">
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Description</label>
              <textarea class="form-control" name="description" rows="3"
                        placeholder="Theme / what to bring"></textarea>
            </div>

            <div class="d-flex justify-content-end gap-2">
              <a href="/admin-dashboard" class="btn btn-secondary">Cancel</a>
              <button type="submit" class="btn btn-success">Add Meetup</button>
            </div>

          </form>

        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>