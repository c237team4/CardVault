<%- include('partials/header', { title: 'Goal Collection - CardVault', user: user }) %>


<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    body {
        background: #0a0c12;
        color: rgb(225, 226, 230);
    }

    .container.my-5 h1 {
        font-family: 'Instrument Serif', Georgia, serif;
        font-size: 3.25rem;
        font-weight: 400;
        color: #f3f1ed;
        letter-spacing: -2px;
    }

    .container.my-5 p.text-muted {
        color: #8b8f9a !important;
    }

    .goal-card {
        background: linear-gradient(160deg, #12151d 0%, #0d1016 100%);
        border: 1px solid rgba(203,166,95,.28);
        border-radius: 14px;
        box-shadow: 0 18px 48px rgba(0,0,0,.55);
        padding: 2rem;
    }

    .card {
    background-color: #fcf8ee !important;
    border: 1px solid lab(84.75% 0.35 40.36);
    border-radius: 12px;
    box-shadow: 0 8px 20px rgba(0,0,0,.15);
}

    .btn-success {
        background: linear-gradient(180deg,#e0bf7c,#cba65f);
        border: none;
        color: #0a0c12;
        font-weight: 600;
    }

    .btn-success:hover {
        background: linear-gradient(180deg,#ecca88,#d9b46e);
        color: #0a0c12;
    }

    .empty-message {
        background: rgba(203,166,95,.08);
        border: 1px solid rgba(203,166,95,.28);
        color: #d8dae0;
        border-radius: 10px;
        padding: 18px;
    }


</style>


<div class="container my-5">

<div class="d-flex justify-content-between align-items-center mb-5">

    <div class="goal-card">

<h1>🏆 Goal Collection</h1>

<p class="text-muted">
Track your card collection goals.
</p>

</div>

<a href="/add-goal" class="btn btn-success">
+ Add Goal
</a>

</div>

<div class="row">

<% if(goals.length > 0){ %>

<% goals.forEach(goal=>{ %>

<div class="col-md-6 mb-4">

<div class="card h-100 shadow">

<div class="card-body">

<h3>
<%= goal.goal_name %>
</h3>

<p>
<%= goal.description %>
</p>

<hr>

<p>

<strong>Progress</strong>

<br>

<%= goal.current_cards %> /

<%= goal.target_cards %>

cards

</p>

<span class="badge bg-primary">
<%= goal.status %>
</span>

<div class="mt-4">

<a href="/goal/<%= goal.goal_id %>"
class="btn btn-dark">

View Goal

</a>

</div>

</div>

</div>

</div>

<% }) %>

<% } else { %>

<div class="col-12">

<div class="alert alert-warning">

No goals created yet.

</div>

</div>

<% } %>

</div>

</div>

</div>

<%- include('partials/footer') %>